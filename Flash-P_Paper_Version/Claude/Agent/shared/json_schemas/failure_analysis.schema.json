{
  "$defs": {
    "Direction": {
      "enum": [
        "increased",
        "decreased",
        "unchanged"
      ],
      "title": "Direction",
      "type": "string"
    },
    "FailureEntry": {
      "properties": {
        "test_id": {
          "title": "Test Id",
          "type": "string"
        },
        "gene": {
          "title": "Gene",
          "type": "string"
        },
        "perturbation_type": {
          "title": "Perturbation Type",
          "type": "string"
        },
        "expected_direction": {
          "$ref": "#/$defs/Direction"
        },
        "predicted_direction": {
          "$ref": "#/$defs/Direction"
        },
        "category": {
          "description": "framework_limitation, epistasis_complexity, combined_perturbation, edge_case",
          "title": "Category",
          "type": "string"
        },
        "explanation": {
          "title": "Explanation",
          "type": "string"
        },
        "evidence": {
          "default": "",
          "title": "Evidence",
          "type": "string"
        },
        "fixable": {
          "default": false,
          "title": "Fixable",
          "type": "boolean"
        },
        "fix_strategy": {
          "default": "",
          "title": "Fix Strategy",
          "type": "string"
        }
      },
      "required": [
        "test_id",
        "gene",
        "perturbation_type",
        "expected_direction",
        "predicted_direction",
        "category",
        "explanation"
      ],
      "title": "FailureEntry",
      "type": "object"
    },
    "FlashPMetadata": {
      "description": "Metadata block present in every pipeline output file.",
      "properties": {
        "flash_p_version": {
          "description": "Pipeline version, e.g. '1.0'",
          "title": "Flash P Version",
          "type": "string"
        },
        "phenotype": {
          "description": "Target phenotype, e.g. 'flowering_time'",
          "title": "Phenotype",
          "type": "string"
        },
        "species": {
          "description": "Species name, e.g. 'Arabidopsis thaliana'",
          "title": "Species",
          "type": "string"
        },
        "created": {
          "description": "Creation date YYYY-MM-DD",
          "title": "Created",
          "type": "string"
        }
      },
      "required": [
        "flash_p_version",
        "phenotype",
        "species",
        "created"
      ],
      "title": "FlashPMetadata",
      "type": "object"
    }
  },
  "properties": {
    "metadata": {
      "$ref": "#/$defs/FlashPMetadata"
    },
    "failures": {
      "items": {
        "$ref": "#/$defs/FailureEntry"
      },
      "title": "Failures",
      "type": "array"
    },
    "summary": {
      "additionalProperties": true,
      "title": "Summary",
      "type": "object"
    }
  },
  "required": [
    "metadata",
    "failures"
  ],
  "title": "FailureAnalysisFile",
  "type": "object"
}