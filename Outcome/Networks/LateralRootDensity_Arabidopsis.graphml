    <edge id="e0" source="TAA1" target="Auxin">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">TAA1 aminotransferase converts Trp to IPA in IAA biosynthesis pathway</data>
      <data key="edge_doi">10.1073/pnas.1108434108</data>
      <data key="edge_evidence">Trp is converted to IPA by TAA1/TARs, and then IPA is converted to IAA by the flavin monooxygenases (YUCCAs)</data>
    </edge>
    <edge id="e1" source="TAR2" target="Auxin">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">TAR2 aminotransferase contributes to IAA biosynthesis under low N</data>
      <data key="edge_doi">10.1111/tpj.12448</data>
      <data key="edge_evidence">Low NO3- restored auxin accumulation in primordial of LRs via TAR2</data>
    </edge>
    <edge id="e2" source="YUC4" target="Auxin">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">YUC4 flavin monooxygenase converts IPA to IAA</data>
      <data key="edge_doi">10.1101/cshperspect.a039933</data>
      <data key="edge_evidence">First step in LR initiation involves formation of auxin maximum dependent on influx carrier AUX1 and activation of YUCCA4-mediated auxin biosynthesis</data>
    </edge>
    <edge id="e3" source="AUX1" target="Auxin">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">AUX1 auxin influx carrier facilitates shoot-derived IAA loading into vasculature</data>
      <data key="edge_doi">10.1101/cshperspect.a039933</data>
      <data key="edge_evidence">AUX1 facilitates loading of shoot-derived IAA into vascular system</data>
    </edge>
    <edge id="e4" source="GH3" target="Auxin">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">GH3 acyl amidosynthetases conjugate IAA to amino acids (inactive)</data>
      <data key="edge_doi">10.1101/cshperspect.a039933</data>
      <data key="edge_evidence">higher levels of auxin led to expression of conjugating enzyme GH3</data>
    </edge>
    <edge id="e5" source="DAO1" target="Auxin">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">DAO1 dioxygenase oxidizes IAA to inactive oxIAA</data>
      <data key="edge_doi">10.1101/cshperspect.a039933</data>
      <data key="edge_evidence">AtDAO1 oxidize endogenous auxin</data>
    </edge>
    <edge id="e6" source="Low_Nitrate" target="TAR2">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Low N stimulates TAR2 auxin biosynthesis gene</data>
      <data key="edge_doi">10.3390/genes11060633</data>
      <data key="edge_evidence">TAR2 is stimulated under low-nitrogen conditions</data>
    </edge>
    <edge id="e7" source="CHL1" target="TAR2">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">NRT1.1 represses TAR2 auxin biosynthesis gene</data>
      <data key="edge_doi">10.1101/cshperspect.a039941</data>
      <data key="edge_evidence">NRT1 controls auxin biosynthesis by repressing expression of TAR2</data>
    </edge>
    <edge id="e8" source="Auxin" target="TIR1">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Auxin binds TIR1/AFB F-box co-receptor to form SCF complex with Aux/IAA substrate</data>
      <data key="edge_doi">10.7554/eLife.54740</data>
      <data key="edge_evidence">auxins are perceived by co-receptor complex consisting of TIR1/AFB... Formation leads to degradation of Aux/IAA protein</data>
    </edge>
    <edge id="e9" source="Low_Phosphate" target="TIR1">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Low Pi upregulates TIR1 to increase auxin sensitivity</data>
      <data key="edge_doi">10.1101/cshperspect.a039933</data>
      <data key="edge_evidence">Phosphate deficiency due to signaling pathway enhancing sensitivity to auxin via up-regulation of TIR1 auxin receptor</data>
    </edge>
    <edge id="e10" source="TIR1" target="IAA14">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">SCF-TIR1 ubiquitinates IAA14 for 26S proteasomal degradation in presence of auxin</data>
      <data key="edge_doi">10.1101/cshperspect.a039933</data>
      <data key="edge_evidence">The auxin signal captured by TIR1/AFBs accelerates the degradation of Aux/IAA proteins such as IAA14/SLR</data>
    </edge>
    <edge id="e11" source="TIR1" target="IAA28">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">SCF-TIR1 degradation of IAA28</data>
      <data key="edge_doi">10.1101/cshperspect.a039933</data>
      <data key="edge_evidence">TIR1/AFBs accelerates the degradation of Aux/IAA proteins such as IAA14/SLR, IAA3/SHY2, IAA19/MSG2, and IAA28</data>
    </edge>
    <edge id="e12" source="IAA14" target="ARF7">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">IAA14 physically binds ARF7 via PB1 domain to repress its transcriptional activity</data>
      <data key="edge_doi">10.1101/cshperspect.a039941</data>
      <data key="edge_evidence">auxin-regulated signaling modules...IAA14-ARF7-LBD16</data>
    </edge>
    <edge id="e13" source="IAA14" target="ARF19">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">IAA14 physically binds ARF19 to repress its activity</data>
      <data key="edge_doi">10.3390/ijms20030486</data>
      <data key="edge_evidence">SLR/IAA14-ARF7 and ARF19 in cortex and epidermis regulate pathways enabling separation</data>
    </edge>
    <edge id="e14" source="IAA28" target="ARF7">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">IAA28 represses ARF6/7/8/19 in basal meristem for founder cell specification</data>
      <data key="edge_doi">10.1101/cshperspect.a039933</data>
      <data key="edge_evidence">GATA23 activated at specific pre-branch sites through IAA28-ARF 6/7/8/19-dependent pathway</data>
    </edge>
    <edge id="e15" source="IAA28" target="ARF19">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">IAA28 represses ARF19 activity in basal meristem</data>
      <data key="edge_doi">10.1101/cshperspect.a039933</data>
      <data key="edge_evidence">IAA28-ARF 6/7/8/19-dependent pathway</data>
    </edge>
    <edge id="e16" source="ARF7" target="LBD">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">ARF7 directly binds LBD16 promoter to activate transcription as primary auxin response [Edge represents composite family; evidence drawn from curated E018 (ARF7-&gt;LBD16).]</data>
      <data key="edge_doi">10.1105/tpc.106.047761</data>
      <data key="edge_evidence">recombinant GST-ARF7 protein, but not GST alone, bound to the single LBD16 promoter</data>
    </edge>
    <edge id="e17" source="ARF19" target="LBD">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">ARF19 binds LBD16 promoter (minor contribution vs ARF7) [Edge represents composite family; evidence drawn from curated E021 (ARF19-&gt;LBD16).]</data>
      <data key="edge_doi">10.1105/tpc.106.047761</data>
      <data key="edge_evidence">ARF19 directly regulates both genes, but LBD16 less so</data>
    </edge>
    <edge id="e18" source="ARF7" target="PLT">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">ARF7 activates PLT3 in incipient LR primordia [Edge represents composite family; evidence drawn from curated E034 (ARF7-&gt;PLT3).]</data>
      <data key="edge_doi">10.1073/pnas.1714410114</data>
      <data key="edge_evidence">upstream auxin response factors ARF7 and ARF19 required to activate expression of early PLT genes</data>
    </edge>
    <edge id="e19" source="ARF19" target="PLT">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">ARF19 redundantly activates PLT3 with ARF7 [Edge represents composite family; evidence drawn from curated E037 (ARF19-&gt;PLT3).]</data>
      <data key="edge_doi">10.1073/pnas.1714410114</data>
      <data key="edge_evidence">ARF7 and ARF19 required to activate expression of early PLT genes</data>
    </edge>
    <edge id="e20" source="LBD" target="LAX3">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">LBD29 directly activates LAX3 auxin influx carrier for cell separation [Edge represents composite family; evidence drawn from curated E027 (LBD29-&gt;LAX3).]</data>
      <data key="edge_doi">10.1101/cshperspect.a039933</data>
      <data key="edge_evidence">LAX3 is downstream target of LBD29, which is direct target of ARF7</data>
    </edge>
    <edge id="e21" source="PLT" target="PIN">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">PLT controls PIN1 expression and polar membrane localization in primordia [Edge represents composite family; evidence drawn from curated E041 (PLT3-&gt;PIN1).]</data>
      <data key="edge_doi">10.1073/pnas.1714410114</data>
      <data key="edge_evidence">from stage II onward, polar localization on plasma membrane of PIN1 impaired in mutant</data>
    </edge>
    <edge id="e22" source="Auxin" target="WOX11">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
