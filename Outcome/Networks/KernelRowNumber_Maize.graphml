    <edge id="e69" source="IM_Size" target="Kernel_Row_Number">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Larger IM produces more spikelet-pair meristems per tier, hence more kernel rows (E022 canonical mapping)</data>
      <data key="edge_doi">10.1105/tpc.114.132506</data>
      <data key="edge_evidence">B73 SAM width: wild-type 179.83 vs fea4 226.16 micrometer; kernel row number: wild-type 17.14 vs fea4 28</data>
    </edge>
    <edge id="e70" source="Ear_Branching" target="Kernel_Row_Number">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Indeterminate branching converts SPMs to branches and disrupts ordered rows, reducing kernel-row counts per ear</data>
      <data key="edge_doi">10.1038/nature03892</data>
      <data key="edge_evidence">The ear, which is usually unbranched, is highly branched in ra1 mutants, resulting in reduced fertility</data>
    </edge>
    <edge id="e71" source="FEA4" target="BA1">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">FEA4 bZIP TF directly upregulates BA1 transcription; BA1 is significantly downregulated in fea4 mutant ears</data>
      <data key="edge_doi">10.1105/tpc.114.132506</data>
      <data key="edge_evidence">BARREN STALK1 downregulated (P=0.002) in fea4 mutants</data>
    </edge>
    <edge id="e72" source="RA1" target="Axillary_Meristem">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">RA1 C2H2 zinc-finger TF imposes determinacy on spikelet-pair meristems, preventing indeterminate AM elaboration</data>
      <data key="edge_doi">10.1242/dev.051748</data>
      <data key="edge_evidence">RA1 imposes determinacy on spikelet-pair meristems, preventing indeterminate branching</data>
    </edge>
    <edge id="e73" source="UB2" target="KN1">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">UB2 SBP-box TF maintains KN1 expression in central meristem redundantly with UB3; loss of KN1 in ub2;ub3 residual IMs</data>
      <data key="edge_doi">10.1073/pnas.1407401112</data>
      <data key="edge_evidence">Loss of KN1 expression in residual inflorescence meristems in ub2;ub3 mutants</data>
    </edge>
    <edge id="e74" source="UB2" target="BIF2">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">UB2 SBP-box TF directly binds the BIF2 promoter; SBP-box consensus motif (GTAC) shared with UB3/TSH4 family</data>
      <data key="edge_doi">10.1093/plcell/koac352</data>
      <data key="edge_evidence">UB2/UB3/TSH4 directly bind BIF2 promoter</data>
    </edge>
    <edge id="e75" source="UB2" target="ZMTCP30">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">UB2 SBP-box TF directly binds and activates the ZmTCP30 promoter in parallel with UB3/TSH4</data>
      <data key="edge_doi">10.1093/plcell/koac352</data>
      <data key="edge_evidence">UB2/UB3/TSH4 could directly regulate the expression of ZmTCP30</data>
    </edge>
    <edge id="e76" source="Cytokinin" target="ZMCKX">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Cytokinin signalling induces ZmCKX cytokinin-oxidase transcription, closing the homeostatic negative-feedback loop (Motif 2-safe: CK-&gt;CKX-&gt;degrade CK is stabilising)</data>
      <data key="edge_doi">10.1007/s00497-024-00510-0</data>
      <data key="edge_evidence">CK signalling activates CKX expression as feedback catabolism of CK</data>
    </edge>
    <edge id="e77" source="FEA4" target="RA3">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">FEA4 bZIP directly activates RA3 TPP transcription; RA3 is significantly downregulated in fea4 mutants</data>
      <data key="edge_doi">10.1105/tpc.114.132506</data>
      <data key="edge_evidence">RAMOSA3 downregulated (P=1.79e-15) in fea4 mutants</data>
    </edge>
    <edge id="e78" source="FEA4" target="Kernel_Row_Number">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">FEA4 bZIP TF directly restricts kernel row number beyond its effects on IM size; Pautler et al. show fea4 mutant ears have increased kernel row number with enlarged IM and ectopic spikelet-pair meristem formation, implicating FEA4 in row-number restriction downstream of the meristem-size expansion phenotype.</data>
      <data key="edge_doi">10.1105/tpc.114.132506</data>
      <data key="edge_evidence">fea4 mutants show enlarged inflorescence meristems and produce ears with increased kernel row number</data>
    </edge>
    <edge id="e79" source="REL2" target="IM_Size">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">REL2 TOPLESS-family corepressor is required for meristem restriction in maize ears; CRISPR rel2 single mutants show ear fasciation consistent with enlarged inflorescence meristem, independent of REL2's role in the RA-complex for branching control.</data>
      <data key="edge_doi">10.1104/pp.18.00913</data>
      <data key="edge_evidence">rel2 mutants display abnormalities in ear development including fasciation and increased kernel row number, indicating REL2 is required to restrict inflorescence meristem size</data>
    </edge>
  </graph>
