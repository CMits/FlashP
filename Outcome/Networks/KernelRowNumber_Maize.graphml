    <edge id="e0" source="ZMCLE7" target="FEA2">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">CLE peptide ligand binds LRR-RLP receptor FEA2</data>
      <data key="edge_doi">10.7554/eLife.35673</data>
      <data key="edge_evidence">FEA2 transmits signaling from two distinct CLE peptides, the maize CLV3 ortholog ZmCLE7 and ZmFCP1</data>
    </edge>
    <edge id="e1" source="ZMCLE7" target="TD1">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">CLV3-like peptide perceived by TD1 (CLV1 ortholog) LRR receptor kinase</data>
      <data key="edge_doi">10.1242/dev.01671</data>
      <data key="edge_evidence">TD1 functions as maize CLV1 ortholog perceiving CLV3-like peptides; td1 fasciated ears phenocopy CLV-pathway loss</data>
    </edge>
    <edge id="e2" source="ZMFCP1" target="FEA2">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">ZmFCP1 also signals through FEA2 (shared receptor with ZmCLE7)</data>
      <data key="edge_doi">10.7554/eLife.35673</data>
      <data key="edge_evidence">FEA2 also participates in ZmFCP1 signaling, in addition to controlling responses to the maize CLV3 ortholog</data>
    </edge>
    <edge id="e3" source="ZMFCP1" target="FEA3">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">ZmFCP1 peptide ligand binds FEA3 LRR-RLP receptor in the rib zone (parallel arm)</data>
      <data key="edge_doi">10.7554/eLife.35673</data>
      <data key="edge_evidence">Both fea3 and fea2 mutants are resistant to the ZmFCP1 peptide</data>
    </edge>
    <edge id="e4" source="FEA2" target="CT2">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">FEA2 receptor couples to heterotrimeric G-alpha subunit CT2 in complex</data>
      <data key="edge_doi">10.7554/eLife.35673</data>
      <data key="edge_evidence">FEA2 interacted with CT2 in co-immunoprecipitation (co-IP) experiments</data>
    </edge>
    <edge id="e5" source="FEA2" target="ZMCRN">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">FEA2 receptor partners with ZmCRN pseudokinase in the signaling complex</data>
      <data key="edge_doi">10.7554/eLife.35673</data>
      <data key="edge_evidence">ZmCRN-mCherry was able to pull down FEA2-Myc</data>
    </edge>
    <edge id="e6" source="TD1" target="IM_Size">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">TD1 LRR-RLK relays CLV3-like CLE signal to restrict meristem proliferation</data>
      <data key="edge_doi">10.1242/dev.01671</data>
      <data key="edge_evidence">td1 female inflorescence is fasciated, with extra rows of kernels</data>
    </edge>
    <edge id="e7" source="CT2" target="IM_Size">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">G-alpha CT2 relays CLV signal from FEA2 complex to restrict stem-cell proliferation</data>
      <data key="edge_doi">10.7554/eLife.35673</data>
      <data key="edge_evidence">ct2 mutants had larger SAMs (157.1 +/- 11.8 micrometer)</data>
    </edge>
    <edge id="e8" source="ZMCRN" target="IM_Size">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">ZmCRN pseudokinase in FEA2 complex restricts meristem proliferation</data>
      <data key="edge_doi">10.7554/eLife.35673</data>
      <data key="edge_evidence">Zmcrn mutants had larger vegetative shoot meristems (130.0 +/- 4.1 micrometer, compared to 109.2 +/- 4.6 micrometer for normal sibs)</data>
    </edge>
    <edge id="e9" source="FEA3" target="ZMWUS1">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">FEA3-ZmFCP1 signaling directly represses ZmWUS1 expression in the rib zone (canonical CLE-WUS repression)</data>
      <data key="edge_doi">10.1038/s41467-021-22699-8</data>
      <data key="edge_evidence">A distinct ZmFCP1-FEA3 ligand-receptor combination prevents WUS gene expression in the rib zone</data>
    </edge>
    <edge id="e10" source="FEA4" target="IM_Size">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">bZIP TF FEA4 promotes peripheral differentiation and limits meristem</data>
      <data key="edge_doi">10.1105/tpc.114.132506</data>
      <data key="edge_evidence">fea4 mutants were also characterized by a larger than normal SAM diameter</data>
    </edge>
    <edge id="e11" source="ABPH2" target="FEA4">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">MSCA1/ABPH2 glutaredoxin post-translationally inhibits FEA4 activity (dominant Abphyl2 allele derepresses meristem)</data>
      <data key="edge_doi">10.1105/tpc.114.130393</data>
      <data key="edge_evidence">FEA4 activity is negatively regulated by MSCA1 based on opposing meristem phenotypes and epistasis analysis</data>
    </edge>
    <edge id="e12" source="ZMEPFL" target="ZMER1">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Five ZmEPFL peptide ligands bind and activate ZmER1 LRR-RLK (redundant composite ligand)</data>
      <data key="edge_doi">10.1038/s41467-025-67634-3</data>
      <data key="edge_evidence">ZmER1 specifically binds to five EPFL peptides, which act redundantly in ear development regulation</data>
    </edge>
    <edge id="e13" source="ZMER1" target="ZMWUS1">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">ZmER-EPFL signaling restricts ZmWUS1 activity; Zmwus1 partially suppresses Zmer1 enlarged-IM phenotype</data>
      <data key="edge_doi">10.1038/s41467-025-67634-3</data>
      <data key="edge_evidence">ZmWUS1 mediates the pathway's effects; mutation in Zmwus1 partially suppresses the enlarged IM of Zmer1 mutants</data>
    </edge>
    <edge id="e14" source="Cytokinin" target="TYPE_B_ARR">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Cytokinin signaling activates Type-B ARRs (AHK-AHP phosphorelay collapsed into this single gate)</data>
      <data key="edge_doi">10.1093/plphys/kiad652</data>
      <data key="edge_evidence">Cytokinin signaling activates type-B ARRs, which then regulate ZmWUS1</data>
    </edge>
    <edge id="e15" source="TYPE_B_ARR" target="ZMWUS1">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Type-B ARRs directly bind AGATAT motifs in the ZmWUS1 proximal promoter and activate transcription</data>
      <data key="edge_doi">10.1038/s41467-021-22699-8</data>
      <data key="edge_evidence">type-B ARRs directly bind to the WUS proximal promoter region and activate its expression</data>
    </edge>
    <edge id="e16" source="TYPE_B_ARR" target="ABPH1">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Type-B ARRs induce CK-responsive type-A response regulator ABPH1 (self-limiting feedback)</data>
      <data key="edge_doi">10.1038/nature02778</data>
      <data key="edge_evidence">ABPH1 transcription is CK-inducible, downstream of type-B ARRs</data>
    </edge>
    <edge id="e17" source="ABPH1" target="ZMWUS1">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Type-A ARR ABPH1 provides negative feedback by damping CK -&gt; ZmWUS1 activation (closes the canonical CK/WUS loop)</data>
      <data key="edge_doi">10.1038/s41467-021-22699-8</data>
      <data key="edge_evidence">Type-A ARR feedback negatively modulates CK-&gt;WUS activation</data>
    </edge>
    <edge id="e18" source="ZMWUS1" target="IM_Size">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">ZmWUS1 homeoprotein is transported via plasmodesmata to the apical domain to maintain the stem-cell pool</data>
      <data key="edge_doi">10.1038/s41467-021-22699-8</data>
      <data key="edge_evidence">WUS is transported via plasmodesmata into the apical domain to promote proliferation of stem cells</data>
    </edge>
    <edge id="e19" source="ZMIPT" target="Cytokinin">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">ZmIPT catalyzes rate-limiting CK biosynthesis (composite with LOG-family CK-activating enzymes)</data>
      <data key="edge_doi">10.1007/s00497-024-00510-0</data>
      <data key="edge_evidence">IPT is the rate-limiting enzyme for cytokinin biosynthesis</data>
    </edge>
    <edge id="e20" source="ZMCKX" target="Cytokinin">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">ZmCKX cytokinin oxidase irreversibly degrades cytokinins (degradation arm of CK homeostasis)</data>
      <data key="edge_doi">10.1007/s00497-024-00510-0</data>
      <data key="edge_evidence">Cytokinin oxidases catalyse irreversible degradation of cytokinins</data>
    </edge>
    <edge id="e21" source="UB3" target="Cytokinin">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">UB3 directly binds LOG1 and Type-A ARR promoters, repressing CK biosynthesis and signaling (net CK down when UB3 up)</data>
      <data key="edge_doi">10.1111/nph.14391</data>
      <data key="edge_evidence">UB3 could bind and regulate the promoters of LONELY GUY1 (LOG1) and Type-A response regulators (ARRs), which participate in cytokinin biosynthesis and signaling; in maize mutants lacking functional UB3 cytokinin biosynthesis-related genes were up-regulated and degradation-related genes were down-regulated</data>
    </edge>
    <edge id="e22" source="VT2" target="Auxin">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">VT2 tryptophan aminotransferase (TAA1 co-ortholog) converts Trp to IPyA in IAA biosynthesis</data>
      <data key="edge_doi">10.1105/tpc.110.075267</data>
      <data key="edge_evidence">vt2 encodes a co-ortholog of TAA1 which converts Trp to indole-3-pyruvic acid</data>
    </edge>
    <edge id="e23" source="SPI1" target="Auxin">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">SPI1 YUCCA-like flavin monooxygenase converts IPyA to IAA (local auxin biosynthesis)</data>
      <data key="edge_doi">10.1073/pnas.0805596105</data>
      <data key="edge_evidence">spi1 encodes a flavin monooxygenase similar to the YUCCA genes involved in local auxin biosynthesis</data>
    </edge>
    <edge id="e24" source="Auxin" target="TIR1">
      <data key="edge_sign">positive</data>
