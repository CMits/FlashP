    <edge id="e0" source="Light" target="PHYB">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Red-light absorption converts inactive Pr phyB to active Pfr phyB form in the nucleus.</data>
      <data key="edge_doi">10.1105/tpc.17.00913</data>
      <data key="edge_evidence">phyB induces light responses across a wide range of light conditions</data>
    </edge>
    <edge id="e1" source="Light" target="PHYA">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Far-red absorption activates phyA; photolabile Pfr translocates to the nucleus.</data>
      <data key="edge_doi">10.1105/tpc.17.00913</data>
      <data key="edge_evidence">phyA mediates far-red light responses</data>
    </edge>
    <edge id="e2" source="Light" target="CRY1">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Blue light activates cryptochrome 1 via FAD photochemistry.</data>
      <data key="edge_doi">10.1016/B978-0-12-801922-1.00007-5</data>
      <data key="edge_evidence">Upon absorption of photons, cryptochromes are photoexcited involving electron transfer</data>
    </edge>
    <edge id="e3" source="Light" target="CRY2">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Blue light activates cryptochrome 2.</data>
      <data key="edge_doi">10.1016/B978-0-12-801922-1.00007-5</data>
      <data key="edge_evidence">cryptochromes are photoexcited involving electron transfer</data>
    </edge>
    <edge id="e4" source="Light" target="UVR8">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">UV-B irradiation monomerizes UVR8 dimer into active form that binds COP1.</data>
      <data key="edge_doi">10.1038/emboj.2009.4</data>
      <data key="edge_evidence">In planta, UV-B stimulates rapid nuclear accumulation of the UVR8 protein</data>
    </edge>
    <edge id="e5" source="Temperature" target="ELF3_EC">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Warm temperature disrupts Evening Complex (ELF3/ELF4/LUX) assembly via ELF3 prion-like domain phase transition.</data>
      <data key="edge_doi">10.1126/sciadv.abf4427</data>
      <data key="edge_evidence">Elevated temperature inactivates ELF3 and releases thermoresponsive growth</data>
    </edge>
    <edge id="e6" source="Temperature" target="HY5">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Warm temperature destabilizes HY5 protein.</data>
      <data key="edge_doi">10.1016/j.xplc.2024.100833</data>
      <data key="edge_evidence">High temperature triggers the degradation of HY5</data>
    </edge>
    <edge id="e7" source="Temperature" target="HSFA1D">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Warm temperature activates HSFA1d heat-shock factor, which stabilizes PIF4 (thermomorphogenesis intermediate — JUDGE S003 iter 2).</data>
      <data key="edge_doi">10.1126/sciadv.adh1738</data>
      <data key="edge_evidence">Warm temperature markedly enhanced daytime accumulation of HSFA1d in light-dependent manner</data>
    </edge>
    <edge id="e8" source="PHYB" target="COP1">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Active phyB physically binds COP1 and promotes its nuclear exclusion, reducing COP1 E3 activity.</data>
      <data key="edge_doi">10.1038/emboj.2009.4</data>
      <data key="edge_evidence">phyB and other photoreceptors antagonize COP1 in the nucleus</data>
    </edge>
    <edge id="e9" source="PHYA" target="COP1">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Active phyA binds and inactivates COP1 in the nucleus.</data>
      <data key="edge_doi">10.1038/emboj.2009.4</data>
      <data key="edge_evidence">FAR1, FHY1 transmit phyA signals to inactivate COP1</data>
    </edge>
    <edge id="e10" source="CRY1" target="COP1">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Photoactivated CRY1 binds COP1/SPA1 and disrupts the complex.</data>
      <data key="edge_doi">10.1016/B978-0-12-801922-1.00007-5</data>
      <data key="edge_evidence">light-dependent suppression of protein degradation via CRY-SPA1/COP1 pathway</data>
    </edge>
    <edge id="e11" source="CRY2" target="COP1">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Photoactivated CRY2 binds COP1 to release HY5 from degradation.</data>
      <data key="edge_doi">10.1016/B978-0-12-801922-1.00007-5</data>
      <data key="edge_evidence">COP1 interacts directly or indirectly with cryptochromes</data>
    </edge>
    <edge id="e12" source="UVR8" target="COP1">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Monomeric UVR8 binds COP1 and prevents COP1-mediated HY5 ubiquitination.</data>
      <data key="edge_doi">10.1038/emboj.2009.4</data>
      <data key="edge_evidence">wild type but not the mutant UVR8 and COP1 proteins directly interact in a UV-B-dependent rapid manner in planta</data>
    </edge>
    <edge id="e13" source="SPA1" target="COP1">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">SPA1 is an obligate co-factor for COP1 E3 ligase activity in the dark; supports COP1 function via direct interaction.</data>
      <data key="edge_doi">10.1111/nph.17332</data>
      <data key="edge_evidence">COP1-SPA complex interacts with and promotes ubiquitination and degradation of HY5</data>
    </edge>
    <edge id="e14" source="COP1" target="HY5">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">COP1-SPA1 ubiquitinates HY5 for proteasomal degradation in the dark.</data>
      <data key="edge_doi">10.1038/emboj.2009.4</data>
      <data key="edge_evidence">COP1 targets different photomorphogenesis-promoting transcription factors for degradation in the dark, among them HY5</data>
    </edge>
    <edge id="e15" source="COP1" target="HFR1">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">COP1 targets HFR1 for degradation in the dark.</data>
      <data key="edge_doi">10.1038/emboj.2009.4</data>
      <data key="edge_evidence">COP1 targets HFR1 for degradation</data>
    </edge>
    <edge id="e16" source="COP1" target="BBX21">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">COP1 ubiquitinates BBX21 for degradation.</data>
      <data key="edge_doi">10.1073/pnas.1607687113</data>
      <data key="edge_evidence">BBX21 is targeted for 26S proteasome-mediated degradation in darkness in a COP1-dependent manner</data>
    </edge>
    <edge id="e17" source="COP1" target="BIN2">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">COP1 promotes BIN2 degradation in response to light (double-lock on BR signaling output).</data>
      <data key="edge_doi">10.1073/pnas.1700850114</data>
      <data key="edge_evidence">COP1 directly interacts with BIN2 in vitro and in vivo; presence of COP1/SPA reduces BIN2-PIF3 interaction</data>
    </edge>
    <edge id="e18" source="BBX21" target="HY5">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">BBX21 physically partners with HY5 to stabilize HY5 binding at photomorphogenic promoters.</data>
      <data key="edge_doi">10.1073/pnas.1607687113</data>
      <data key="edge_evidence">BBX21 directly binds to the T/G-box in the HY5 promoter and directly activates HY5 expression</data>
    </edge>
    <edge id="e19" source="UVR8" target="HY5">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">UVR8 positively regulates HY5 expression through COP1 sequestration and direct HY5 gene activation.</data>
      <data key="edge_doi">10.1038/emboj.2009.4</data>
      <data key="edge_evidence">UVR8 associates constitutively with chromatin regions of several UV-B-activated genes, including the HY5 genomic locus</data>
    </edge>
    <edge id="e20" source="UVR8" target="PIF5">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">UV-B destabilizes PIF5.</data>
      <data key="edge_doi">10.1111/tpj.14556</data>
      <data key="edge_evidence">PIF4-HA and PIF5-HA protein levels decrease under UV-B in UVR8-dependent manner</data>
    </edge>
    <edge id="e21" source="PHYB" target="PIF3">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Active phyB Pfr phosphorylates PIF3 on multiple residues, targeting it for ubiquitin-mediated degradation.</data>
      <data key="edge_doi">10.1111/j.1365-313X.2012.05114.x</data>
      <data key="edge_evidence">PIF3 exhibited light-induced phosphorylation and degradation</data>
    </edge>
    <edge id="e22" source="PHYB" target="PIF4">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Active phyB Pfr phosphorylates PIF4 and promotes its degradation.</data>
      <data key="edge_doi">10.1105/tpc.107.052142</data>
      <data key="edge_evidence">phyB levels are increased by 1.6 to 1.8-fold in pif4 relative to wild-type levels</data>
    </edge>
    <edge id="e23" source="PHYB" target="PIF5">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Active phyB Pfr phosphorylates PIF5 and promotes its degradation.</data>
      <data key="edge_doi">10.1111/tpj.14556</data>
      <data key="edge_evidence">PIF4 and PIF5 are direct substrates of phytochrome-mediated phosphorylation</data>
    </edge>
    <edge id="e24" source="PHYB" target="PIF7">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
