      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">EIN3 and PIF3 cooperatively induce elongation genes in dark; EIN3 stabilizes PIF3 protein.</data>
      <data key="edge_doi">10.1007/s42994-021-00063-0</data>
      <data key="edge_evidence">ethylene induces the transcription of PIF3 through EIN3</data>
    </edge>
    <edge id="e73" source="PIF3" target="Hypocotyl_Length">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">PIF3 activates cell-elongation genes (expansins, XTR7) in the hypocotyl epidermis in darkness.</data>
      <data key="edge_doi">10.1105/tpc.107.052142</data>
      <data key="edge_evidence">pif3 mutants are hypersensitive to all Rc fluence rates tested</data>
    </edge>
    <edge id="e74" source="PIF4" target="Hypocotyl_Length">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">PIF4 directly induces SAUR-family and expansin genes driving cell elongation.</data>
      <data key="edge_doi">10.1111/tpj.14556</data>
      <data key="edge_evidence">pif4 pif5 mutants exhibited reduced hypocotyl elongation compared with the WT in the absence of UV-B</data>
    </edge>
    <edge id="e75" source="PIF5" target="Hypocotyl_Length">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">PIF5 redundantly with PIF3/4 activates elongation genes.</data>
      <data key="edge_doi">10.1111/tpj.14556</data>
      <data key="edge_evidence">PIF4 and PIF5 are known negative regulators of photomorphogenesis that mediate hypocotyl elongation</data>
    </edge>
    <edge id="e76" source="BZR1" target="Hypocotyl_Length">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Unphosphorylated BZR1 promotes hypocotyl cell elongation by activating cell-wall loosening genes.</data>
      <data key="edge_doi">10.1016/j.pbi.2014.07.012</data>
      <data key="edge_evidence">bes1-D dominant mutant shows BR-hypersensitive phenotype with increased elongation</data>
    </edge>
    <edge id="e77" source="ARF6" target="Hypocotyl_Length">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">ARF6/7/8 activate SAUR19, PRE1, expansins; auxin signaling drives cell elongation.</data>
      <data key="edge_doi">10.1016/j.pbi.2014.07.012</data>
      <data key="edge_evidence">ARF6 target genes encode cell wall proteins involved in cell expansion</data>
    </edge>
    <edge id="e78" source="HY5" target="Hypocotyl_Length">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">HY5 directly represses elongation and cell-expansion genes; hy5 mutants have long hypocotyl in light.</data>
      <data key="edge_doi">10.1111/nph.17332</data>
      <data key="edge_evidence">HY5 is a key positive regulator that promotes photomorphogenesis; hy5 mutant showed relatively longer hypocotyl</data>
    </edge>
    <edge id="e79" source="DELLA" target="Hypocotyl_Length">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">DELLA proteins repress elongation by sequestering PIF3/PIF4, BZR1, ARF6 and by direct target repression.</data>
      <data key="edge_doi">10.1199/tab.0103</data>
      <data key="edge_evidence">GA-deficient mutants are extreme dwarfs with much reduced hypocotyl lengths</data>
    </edge>
    <edge id="e80" source="EIN3" target="Hypocotyl_Length">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">In darkness, EIN3 stabilization shortens hypocotyl (triple response); ein3 loss restores elongation under ACC.</data>
      <data key="edge_doi">10.1105/tpc.110.076588</data>
      <data key="edge_evidence">EIN3 overexpression shows ethylene hypersensitivity (short hypocotyl in dark)</data>
    </edge>
    <edge id="e81" source="TOC1" target="PIF4">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">TOC1 (PRR1) binds the PIF4 promoter at dawn and represses transcription; toc1 mutants have long hypocotyl. Clock gate on PIF4 (JUDGE S001).</data>
      <data key="edge_doi">10.1016/j.xplc.2024.100833</data>
      <data key="edge_evidence">TOC1 represses both the transcription of PIF4 and the transcriptional activation activity of its protein</data>
    </edge>
    <edge id="e82" source="GI" target="PIF4">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">GIGANTEA represses PIF4 as part of the clock-output circuit (Nohales 2019). gi mutants have altered hypocotyl elongation (JUDGE S002).</data>
      <data key="edge_doi">10.1016/j.xplc.2024.100833</data>
      <data key="edge_evidence">GI inhibits PIF4 by preventing PIF4 overactivation; this inhibition depends partially on TOC1</data>
    </edge>
    <edge id="e83" source="ELF3_EC" target="GI">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">ELF3 (and the Evening Complex) represses GI transcription at dusk; ELF3_EC inactivation at warm temperature de-represses GI (JUDGE S002).</data>
      <data key="edge_doi">10.1016/j.xplc.2024.100833</data>
      <data key="edge_evidence">Loss of ELF3 resulted in increased GI transcript levels; ELF3 represses GI transcription</data>
    </edge>
    <edge id="e84" source="PIF4" target="GI">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">PIF4 binds the GI promoter and activates transcription. Closes SAFE negative feedback loop PIF4 -&gt; GI -| PIF4 (stabilizing).</data>
      <data key="edge_doi">10.1016/j.xplc.2024.100833</data>
      <data key="edge_evidence">PIF4 directly activates GI transcription in concert with other PIFs</data>
    </edge>
    <edge id="e85" source="HSFA1D" target="PIF4">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">HSFA1d binds PIF4 and stabilizes the protein at warm temperature; canonical thermomorphogenesis intermediate (JUDGE S003).</data>
      <data key="edge_doi">10.1126/sciadv.adh1738</data>
      <data key="edge_evidence">HSFA1d interacts with PIF4 and stabilizes it by interfering with phytochrome B interaction</data>
    </edge>
    <edge id="e86" source="COP1" target="HSFA1D">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">COP1 positively regulates HSFA1d stability in darkness, contributing to PIF4 stabilization pathway (JUDGE S003).</data>
      <data key="edge_doi">10.1126/sciadv.adh1738</data>
      <data key="edge_evidence">COP1 facilitates warm temperature-triggered HSFA1d nuclear localization by suppressing BIN2-mediated HSFA1d phosphorylation</data>
    </edge>
    <edge id="e87" source="BIN2" target="HSFA1D">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">BIN2 phosphorylates HSFA1d and promotes its degradation, coupling BR signaling to thermo response (JUDGE S003 / BIN2 Multi-Output).</data>
      <data key="edge_doi">10.1126/sciadv.adh1738</data>
      <data key="edge_evidence">BIN2 inhibits nuclear translocation of HSFA1d by phosphorylating its NLS motif</data>
    </edge>
    <edge id="e88" source="PHYB" target="BBX11">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">phyB directly induces BBX11 expression in red light, complementing BBX21 (JUDGE S004).</data>
      <data key="edge_doi">10.1016/j.xplc.2020.100045</data>
      <data key="edge_evidence">BBX11 expression significantly decreased in phyB-9 mutant under red light</data>
    </edge>
    <edge id="e89" source="CRY1" target="BBX11">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">CRY1 induces BBX11 expression in blue light (JUDGE S004).</data>
      <data key="edge_doi">10.1016/j.xplc.2020.100045</data>
      <data key="edge_evidence">BBX11 expression significantly decreased in cry1-304 mutant under blue light</data>
    </edge>
    <edge id="e90" source="BBX21" target="BBX11">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">BBX21 activates BBX11 transcription; parallel HY5-positive cofactors (JUDGE S004).</data>
      <data key="edge_doi">10.1016/j.xplc.2020.100045</data>
      <data key="edge_evidence">BBX21 binds BBX11 promoter and positively regulates its expression</data>
    </edge>
    <edge id="e91" source="BBX11" target="HY5">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">BBX11 binds HY5 and stabilizes its transcriptional activity (JUDGE S004). HY5-&gt;BBX11 reverse arm intentionally excluded to prevent positive-feedback loop (Trap 1).</data>
      <data key="edge_doi">10.1016/j.xplc.2020.100045</data>
      <data key="edge_evidence">BBX11 directly binds to the HY5 promoter region B containing E-box and T/G-box cis-elements to activate transcription</data>
    </edge>
    <edge id="e92" source="BIN2" target="PIF3">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">BIN2 phosphorylates PIF3 and promotes its degradation; BR-mediated PIF3 destabilization (JUDGE S005).</data>
      <data key="edge_doi">10.1073/pnas.1700850114</data>
      <data key="edge_evidence">BIN2 kinase induces PIF3 degradation via 26S proteasome during skotomorphogenesis</data>
    </edge>
    <edge id="e93" source="SPA1" target="HY5">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">SPA1 (within CUL4-COP1-SPA1 complex) directly ubiquitinates HY5 (JUDGE S006).</data>
      <data key="edge_doi">10.1111/nph.17332</data>
      <data key="edge_evidence">SPA1 directly phosphorylates HY5 in vitro in a concentration and time-dependent manner</data>
    </edge>
    <edge id="e94" source="SPA1" target="BIN2">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">SPA1 promotes BIN2 degradation in light, completing SPA1 Multi-Output Scaffold (JUDGE S006).</data>
      <data key="edge_doi">10.1073/pnas.1700850114</data>
      <data key="edge_evidence">SPA1 presence reduces BIN2-PIF3 interaction through competing for same PIF3 regions</data>
    </edge>
    <edge id="e95" source="CPD" target="BR">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">CPD (CYP90A1) catalyzes 23-alpha hydroxylation in BR biosynthesis; cpd null mutants are severe dwarfs (JUDGE S007).</data>
      <data key="edge_doi">10.1016/j.pbi.2014.07.012</data>
      <data key="edge_evidence">CPD is defective in the 23α-hydroxylation step</data>
    </edge>
    <edge id="e96" source="PHYA" target="FHY1">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Active phyA induces FHY1 transcription, part of the positive FHY1-phyA feedforward for far-red signaling (JUDGE S008). FHY1 -&gt; PHYA reverse arm excluded to avoid positive feedback.</data>
      <data key="edge_doi">10.1371/journal.pgen.1000143</data>
      <data key="edge_evidence">Nuclear accumulation of phyA is dependent on two related proteins called FHY1 and FHL</data>
    </edge>
    <edge id="e97" source="FHY1" target="HFR1">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">FHY1 transmits phyA signal to HFR1 induction, providing far-red-specific HFR1 accumulation that brakes PIF4 (JUDGE S008).</data>
      <data key="edge_doi">10.1105/tpc.109.067215</data>
      <data key="edge_evidence">N-terminal regions of FHY1 and FHL interact with HFR1 in vitro</data>
    </edge>
    <edge id="e98" source="PIF5" target="HFR1">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">PIF5 induces HFR1 transcription under shade; creates safe negative feedback brake on PIF4 (Motif 2) (JUDGE S009).</data>
      <data key="edge_doi">10.3390/plants7040102</data>
      <data key="edge_evidence">HFR1/SICS1 is rapidly induced by FR-enriched light and recognized in vivo by PIF5</data>
    </edge>
    <edge id="e99" source="COP1" target="HYH">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">COP1 ubiquitinates HYH for degradation, parallel to HY5 (JUDGE S010).</data>
      <data key="edge_doi">10.1111/nph.17332</data>
      <data key="edge_evidence">COP1-SPA complex interacts with and promotes ubiquitination and degradation of HY5/HYH</data>
    </edge>
    <edge id="e100" source="HYH" target="Hypocotyl_Length">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">HYH redundantly with HY5 represses elongation genes; hyh mutants enhance hy5 long-hypocotyl phenotype (JUDGE S010).</data>
      <data key="edge_doi">10.1111/tpj.14556</data>
      <data key="edge_evidence">HY5 and its homologue HYH are key effectors of the UVR8 pathway</data>
    </edge>
    <edge id="e101" source="COP1" target="BBX25">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">COP1 degrades BBX25, removing the HY5 antagonist in light (JUDGE S010).</data>
      <data key="edge_doi">10.1105/tpc.113.109751</data>
      <data key="edge_evidence">BBX25 undergoes COP1-mediated degradation via 26S Proteasome Pathway</data>
    </edge>
    <edge id="e102" source="BBX25" target="HY5">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">BBX25 competes with BBX21/BBX22/BBX11 at HY5 promoter, antagonizing HY5 activity (JUDGE S010).</data>
      <data key="edge_doi">10.1105/tpc.113.109751</data>
      <data key="edge_evidence">BBX25 physically interacts with HY5 through B-box domains with bZIP domain of HY5, reducing HY5 transcriptional activity</data>
    </edge>
  </graph>
