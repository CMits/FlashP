      <data key="edge_doi">10.3390/molecules25143136</data>
      <data key="edge_evidence">FPP, in turn, is catalyzed by geranylgeranyl diphosphate (GGPP) synthase (CrtE)</data>
    </edge>
    <edge id="e65" source="GPP" target="MVK">
