    <edge id="e33" source="Acetyl_CoA" target="Mevalonate">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Acetyl-CoA is the primary substrate of the MVA upper pathway (AtoB/HMGS/HMGR).</data>
      <data key="edge_doi">10.3390/molecules25143136</data>
      <data key="edge_evidence">MVA pathway initiates with acetyl-CoA, which is converted into MVA through three reactions, catalyzed by acetoacetyl-CoA thiolase (ACCT), 3-hydroxy-3-methylglutaryl-CoA (HMG-CoA) synthase (HMGS)</data>
    </edge>
    <edge id="e34" source="ATOB" target="Mevalonate">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">AtoB condenses two Acetyl-CoA to acetoacetyl-CoA; first committed MVA step.</data>
      <data key="edge_doi">10.1016/j.synbio.2021.04.001</data>
      <data key="edge_evidence">mvaE and mvaS...catalyzes the conversion from acetyl-CoA to mevalonic acid</data>
    </edge>
    <edge id="e35" source="HMGS" target="Mevalonate">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">HMGS condenses acetoacetyl-CoA + Acetyl-CoA to HMG-CoA.</data>
      <data key="edge_doi">10.3390/molecules25143136</data>
      <data key="edge_evidence">catalyzed by acetoacetyl-CoA thiolase (ACCT), 3-hydroxy-3-methylglutaryl-CoA (HMG-CoA) synthase (HMGS) and HMG-CoA reductase (HMGR)</data>
    </edge>
