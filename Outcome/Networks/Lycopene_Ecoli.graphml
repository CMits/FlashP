      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Composite membrane-biogenesis enzyme-family activator of Lycopene_Titer. OE of any member (PlsB, PlsC, DgkA, Almgs) expands hydrophobic membrane reservoir for lycopene sequestration (Hu 2018 synergy).</data>
      <data key="edge_doi">10.3390/molecules25143136</data>
      <data key="edge_evidence">Plsb (glycerol-3-phosphate acyltransferase) and Plsc...were overexpressed...cells produced sufficient intracellular membrane vesicles</data>
    </edge>
    <edge id="e91" source="NADPH" target="Mevalonate">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">HMGR requires 2 NADPH per mevalonate. NADPH availability is rate-limiting; MVA pathway consumes 2 NADPH per IPP vs MEP which produces net NADH but consumes NADPH for IspG/IspH.</data>
      <data key="edge_doi">10.1016/j.synbio.2021.04.001</data>
      <data key="edge_evidence">MVA pathway needs 2 NADPH for the production of mevalonate</data>
