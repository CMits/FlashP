      <data key="edge_evidence">isopentenyl pyrophosphate (IPP), dimethylallyl pyrophosphate (DMAPP) and farnesyl pyrophosphate (FPP) are synthesized by 8 sequential enzymes in the MEP pathway, after which they are converted to lycopene</data>
    </edge>
    <edge id="e64" source="ISPB" target="FPP">
      <data key="edge_sign">negative</data>
