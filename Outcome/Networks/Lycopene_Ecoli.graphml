      <data key="edge_doi">10.3390/biom13121747</data>
      <data key="edge_evidence">overexpressed tHMGR from X. dendrorhous, a truncated form of HMGR...2.2-fold enhancement in beta-carotene production</data>
    </edge>
    <edge id="e37" source="NADPH" target="HMGR">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
