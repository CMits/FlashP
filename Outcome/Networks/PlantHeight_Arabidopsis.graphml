    <edge id="e0" source="Sucrose" target="miR156">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Sucrose (and its hydrolytic hexose products glucose/fructose) represses MIR156A and MIR156C gene transcription, reducing mature miR156 levels to promote juvenile-to-adult transition</data>
      <data key="edge_doi">10.7554/eLife.00260</data>
      <data key="edge_evidence">Glucose and fructose repressed the accumulation of miR156 by about 50%; exogenous sucrose significantly accelerates abaxial trichome production in wild-type plants</data>
    </edge>
    <edge id="e1" source="miR156" target="SPL9">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">miR156 targets SPL9 mRNA for cleavage and translational repression; high miR156 in juvenile phase keeps SPL9 levels low</data>
      <data key="edge_doi">10.1016/j.cell.2009.06.031</data>
      <data key="edge_evidence">miR156 represses SPL2, SPL3, SPL4, SPL5, SPL6, SPL9, SPL10, SPL11, SPL13, SPL15 via microRNA cleavage/translational repression</data>
    </edge>
    <edge id="e2" source="SPL9" target="Plant_Height">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">SPL9 promotes floral transition and shoot maturation; higher SPL9 activity leads to earlier flowering and shorter inflorescence stems. spl9 spl15 double mutant showed significantly reduced inflorescence height (6.9 cm vs 12.1 cm in wild-type) demonstrating SPL9 shortens plant height via earlier reproductive transition</data>
      <data key="edge_doi">10.1007/s11103-008-9310-z</data>
      <data key="edge_evidence">Inflorescence height was measured between the rosette and the first flower; double mutant showed significantly reduced height (6.9 cm vs 12.1 cm in wild-type); double mutant bolted and flowered somewhat later than wild-type (bolting 18.5 DAS vs 16.3 DAS)</data>
    </edge>
    <edge id="e3" source="Cold_Vernalization" target="VIN3">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Extended cold exposure progressively induces VIN3 transcription via unknown cold sensors</data>
      <data key="edge_doi">10.1073/pnas.0606385103</data>
      <data key="edge_evidence">VIN3 mRNA is present at very low abundance during growth at warm temperatures, with expression increasing progressively during a vernalization treatment</data>
    </edge>
    <edge id="e4" source="VIN3" target="FLC">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">VIN3 PHD protein joins PRC2-like complex to deposit H3K27me3 at FLC and silence it</data>
      <data key="edge_doi">10.1073/pnas.0606385103</data>
      <data key="edge_evidence">Loss of VIN3 function prevents loss of H3Ac and methylation of H3K9 and H3K27 in vernalized plants</data>
    </edge>
    <edge id="e5" source="FRI" target="FLC">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">FRI (FRIGIDA) is a coiled-coil protein that recruits chromatin modifiers to activate FLC expression to high levels</data>
      <data key="edge_doi">10.1105/tpc.12.6.885</data>
      <data key="edge_evidence">FRI is required for high levels of FLC expression and confers the late-flowering winter-annual habit</data>
    </edge>
    <edge id="e6" source="FLC" target="FT">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">FLC (MADS-box transcription factor) directly represses FT expression by binding to its promoter/regulatory regions, delaying flowering</data>
      <data key="edge_doi">10.1007/s12298-017-0458-3</data>
      <data key="edge_evidence">FLC encodes a MADS box protein that functions as a central repressor of flowering time in Arabidopsis; FLC directly represses FT and SOC1 expression</data>
    </edge>
    <edge id="e7" source="Light" target="PHYB">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Red light converts phyB to active Pfr form; far-red converts back to inactive Pr</data>
      <data key="edge_doi">10.3389/fpls.2019.00914</data>
      <data key="edge_evidence">High R:FR light activates phyB (Pfr form)</data>
    </edge>
    <edge id="e8" source="Light" target="HFR1">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Low R:FR (shade) transcriptionally induces HFR1 via phytochromes as a negative-feedback brake</data>
      <data key="edge_doi">10.1038/emboj.2009.306</data>
      <data key="edge_evidence">HFR1 (long hypocotyl in FR light) is transcriptionally induced by shade and inhibits this response; HFR1 is induced in a phytochrome-regulated manner</data>
    </edge>
    <edge id="e9" source="PHYB" target="PIF4_5_7">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Light-activated phyB binds PIF4 to promote its phosphorylation-dependent degradation</data>
      <data key="edge_doi">10.1038/s41467-020-14905-w</data>
      <data key="edge_evidence">phyB directly interacts with PIF4 to promote PIF4 phosphorylation and degradation, repressing thermoresponsive growth</data>
    </edge>
    <edge id="e10" source="HFR1" target="PIF4_5_7">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">HFR1 forms non-DNA-binding heterodimers with PIF4, blocking PIF4 DNA binding without degradation</data>
      <data key="edge_doi">10.1038/emboj.2009.306</data>
      <data key="edge_evidence">HFR1 directly inhibits these PIFs by forming non-DNA-binding heterodimers with PIF4 and PIF5</data>
    </edge>
    <edge id="e11" source="PAR1" target="PIF4_5_7">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">PAR1 small HLH prevents PIF4 from binding DNA</data>
      <data key="edge_doi">10.1038/emboj.2009.306</data>
      <data key="edge_evidence">PAR1 and PAR2 are negative regulators of the shade avoidance response, which may also act by preventing other bHLH proteins from binding to DNA. The mechanism of action of PAR1 is apparently similar to that of HFR1</data>
    </edge>
    <edge id="e12" source="Temperature" target="PIF4_5_7">
      <data key="edge_sign">positive</data>
