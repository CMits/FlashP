      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">TFL1-FD complex represses LFY by binding G-box/bZIP motifs in the LFY second exon</data>
      <data key="edge_doi">10.1038/s41467-020-18782-1</data>
      <data key="edge_evidence">LFY: Repression via exonic G-box and C-boxes; reporters with mutated bZIP sites show ectopic expression in apex</data>
    </edge>
    <edge id="e75" source="AP1" target="TFL1">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">AP1 directly binds essential cis-regulatory elements in the TFL1 promoter to repress it</data>
      <data key="edge_doi">10.1105/tpc.11.6.1007</data>
      <data key="edge_evidence">TFL1 expression is downregulated in plants constitutively expressing AP1</data>
    </edge>
    <edge id="e76" source="TFL1" target="SOC1">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">TFL1-FD complex directly represses SOC1 at shared loci</data>
      <data key="edge_doi">10.1038/s41467-020-18782-1</data>
      <data key="edge_evidence">SOC1, GI, CO: Direct repression (reproductive development genes); ChIP peaks at reproductive development loci</data>
    </edge>
    <edge id="e77" source="TFL1" target="FD">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">TFL1 interacts physically with FD in the nucleus, forming repressor complex</data>
      <data key="edge_doi">10.1105/tpc.111.088641</data>
      <data key="edge_evidence">TFL1 interacts with FD in the nucleus (BiFC assay)</data>
    </edge>
    <edge id="e78" source="TFL1" target="Flowering_Time">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">TFL1 maintains inflorescence indeterminacy and delays floral transition; tfl1 mutants flower early</data>
      <data key="edge_doi">10.1105/tpc.111.088641</data>
      <data key="edge_evidence">Early flowering: Reduced rosette leaves at bolting (22C, long-day); tfl1 mutants show determinate inflorescence</data>
    </edge>
    <edge id="e79" source="AP1" target="Flowering_Time">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">AP1 is a floral meristem identity gene promoting flowering</data>
      <data key="edge_doi">10.1371/journal.pgen.1006263</data>
      <data key="edge_evidence">spl2/9/11/13/15 mutants showed reduced LFY, AP1, FUL, and SOC1 transcripts; AP1 specifies floral meristem identity.</data>
    </edge>
    <edge id="e80" source="LFY" target="Flowering_Time">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">LFY is a floral meristem identity gene promoting flower formation</data>
      <data key="edge_doi">10.1371/journal.pgen.1006263</data>
      <data key="edge_evidence">spl2/9/11/13/15 mutants showed reduced LFY, AP1, FUL, and SOC1 transcripts; LFY required for floral induction.</data>
    </edge>
    <edge id="e81" source="SOC1" target="Flowering_Time">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">SOC1 integrates photoperiod/GA/vernalization signals to activate meristem identity genes</data>
      <data key="edge_doi">10.1093/jxb/eraa057</data>
      <data key="edge_evidence">SPL9 and SPL15 functionally cooperate with the MADS-box protein SOC1 to activate FRUITFULL (FUL)</data>
    </edge>
    <edge id="e82" source="TFL1" target="FUL">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">TFL1-FD complex directly represses FUL</data>
      <data key="edge_doi">10.1038/s41467-020-18782-1</data>
      <data key="edge_evidence">AP1, FUL: Direct TFL1-FD repression (floral fate genes)</data>
    </edge>
    <edge id="e83" source="SOC1" target="FUL">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">SOC1 activates FUL transcription as part of floral transition program</data>
      <data key="edge_doi">10.3389/fpls.2022.852047</data>
      <data key="edge_evidence">SOC1 receives input from vernalization, GA, photoperiod, aging pathways; upregulates LFY and AP1 (and FUL)</data>
    </edge>
    <edge id="e84" source="AP2" target="miR172">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">AP2 directly represses miR172b transcription (negative feedback loop)</data>
      <data key="edge_doi">10.1105/tpc.110.075606</data>
      <data key="edge_evidence">miR172b: AP2 negatively regulates; miR172 levels were 270% of those in the wild type in ap2 mutants</data>
    </edge>
    <edge id="e85" source="TPS1" target="FT">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">TPS1 via T6P production in leaves is required for FT expression</data>
      <data key="edge_doi">10.1093/jxb/ert457</data>
      <data key="edge_evidence">tps1 rescued plants: Stunted and late flowering with near loss of FLOWERING LOCUS T expression in the leaves</data>
    </edge>
    <edge id="e86" source="FT" target="Flowering_Time">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">FT florigen travels from leaves to shoot apex and forms FT-FD complex to initiate floral transition</data>
      <data key="edge_doi">10.1093/jxb/eraa057</data>
      <data key="edge_evidence">CO binds to a proximal CO response element (CORE) in the promoter of FT, and interacts with the NF-Y-FE complex</data>
    </edge>
