      <data key="edge_doi">10.1199/tab.0103</data>
      <data key="edge_evidence">GA de-represses its signaling pathway by binding to GID1s, which induce degradation of GA signaling repressors (DELLAs) via an ubiquitin-proteasome pathway</data>
    </edge>
    <edge id="e29" source="SLY1" target="DELLA">
