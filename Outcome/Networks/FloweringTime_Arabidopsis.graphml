    <edge id="e0" source="Long_Day" target="CO">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">LD afternoon coincides with CO mRNA peak (driven by FKF1-GI-mediated CDF degradation) and stabilizes CO protein; SD degrades CO</data>
      <data key="edge_doi">10.1104/pp.16.01327</data>
      <data key="edge_evidence">CO protein is stabilized in LD conditions but degraded in SD conditions</data>
    </edge>
    <edge id="e1" source="Blue_Light" target="FKF1">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Blue light activates FKF1 LOV domain to form FKF1-GI complex</data>
      <data key="edge_doi">10.1126/science.1146994</data>
      <data key="edge_evidence">FKF1 and GI proteins form a complex in a blue-light dependent manner</data>
    </edge>
    <edge id="e2" source="GI" target="FKF1">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">GI physically binds FKF1 in a blue-light-dependent manner via FKF1 LOV domain; stabilizes FKF1 nuclear abundance</data>
      <data key="edge_doi">10.1126/science.1146994</data>
      <data key="edge_evidence">FKF1 and GI proteins form a complex in a blue-light dependent manner</data>
    </edge>
    <edge id="e3" source="FKF1" target="CDF1">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">FKF1 forms SCF(FKF1) E3 ligase complex with ASK1, ASK2, CUL1 and targets CDF1 for ubiquitin-mediated degradation in late afternoon</data>
      <data key="edge_doi">10.1126/science.1146994</data>
      <data key="edge_evidence">FKF1 regulates CO by degrading its repressor, CDF1</data>
    </edge>
    <edge id="e4" source="GI" target="CDF1">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">GI forms complex with FKF1 that degrades CDFs in afternoon</data>
      <data key="edge_doi">10.1199/tab.0178</data>
      <data key="edge_evidence">CDF repression of CO is released in the afternoon through the action of a blue light induced complex composed of the GIGANTEA (GI) protein and the LOV domain blue-light photoreceptor E3 ubiquitin ligase FLAVIN BINDING, KELCH REPEAT, F-BOX 1 (FKF1)</data>
    </edge>
    <edge id="e5" source="CDF1" target="CO">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">CDF1-5 bind DOF cis-elements in CO promoter in the morning and recruit TOPLESS/TPR co-repressors</data>
      <data key="edge_doi">10.1016/j.xplc.2023.100552</data>
      <data key="edge_evidence">CYCLING DOF FACTOR 1 (CDF1) to CDF5 were the first CO regulators identified, strongly repressing CO transcription by recruiting TOPLESS(TPL)/TPL-RELATED (TPR) co-repressors</data>
    </edge>
    <edge id="e6" source="GI" target="CO">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">GI activates CO expression via FKF1-mediated degradation of CDF repressors; GI also partners with FKF1 to stabilize afternoon CO protein</data>
      <data key="edge_doi">10.1111/tpj.12759</data>
      <data key="edge_evidence">GI was shown to activate expression of the key floral regulators CONSTANS (CO) and FLOWERING LOCUS T (FT) by facilitating degradation of a family of CYCLING DOF FACTOR (CDF) transcriptional repressors</data>
    </edge>
    <edge id="e7" source="FKF1" target="CO">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">FKF1 binds CO through LOV domain in blue-light-enhanced manner; prevents COP1 homodimer formation, stabilizing CO in LD afternoon</data>
      <data key="edge_doi">10.1073/pnas.1415375111</data>
      <data key="edge_evidence">FKF1 binds to CO through the LOV domain in a blue light-enhanced manner and stabilizes CO specifically in the LD afternoon</data>
    </edge>
    <edge id="e8" source="CO" target="FT">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">CO binds directly to CORE cis-elements in FT promoter; CO-NF-Y complex brings distal NF-Y binding sites to proximal CORE via chromatin looping</data>
      <data key="edge_doi">10.1104/pp.16.01327</data>
      <data key="edge_evidence">CO binds to the cis-element referred to as CO Responsive Element (CORE) in the FT promoter</data>
    </edge>
    <edge id="e9" source="FRI" target="FLC">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">FRI forms scaffold complex (FRI-C) with FRL1/FES1/SUF4/FLX to activate FLC via chromatin modifier recruitment</data>
      <data key="edge_doi">10.1199/tab.0171</data>
      <data key="edge_evidence">FRI mainly acts to up-regulate FLC transcription and thus contributes to the vernalization requirement</data>
    </edge>
    <edge id="e10" source="Cold" target="VIN3">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Prolonged cold progressively induces VIN3 transcription</data>
      <data key="edge_doi">10.4161/psb.5.11.13465</data>
      <data key="edge_evidence">The most direct link between measurement of the duration of cold and the output of vernalization response is the induction of VIN3 expression, which is tightly linked to prolonged cold exposure</data>
    </edge>
    <edge id="e11" source="Vernalization" target="VIN3">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Vernalizing cold progressively activates VIN3 via H3K4me3</data>
      <data key="edge_doi">10.1073/pnas.0606385103</data>
      <data key="edge_evidence">VIN3 mRNA is present at very low abundance during growth at warm temperatures, with expression increasing progressively during vernalization</data>
    </edge>
    <edge id="e12" source="VIN3" target="FLC">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">VIN3 PHD protein binds H3K9me2 and recruits PRC2 for H3K27me3 silencing</data>
      <data key="edge_doi">10.1199/tab.0171</data>
      <data key="edge_evidence">all VIN3 family proteins preferentially bind to H3K9me2 peptides in vitro through PHD motifs</data>
    </edge>
    <edge id="e13" source="PRC2" target="FLC">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">PRC2 catalyzes H3K27me3 at FLC</data>
      <data key="edge_doi">10.1111/tpj.14817</data>
      <data key="edge_evidence">PRC2 catalyzes tri-methylation of histone H3K27</data>
    </edge>
    <edge id="e14" source="FCA" target="FLC">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">FCA autonomous-pathway RBP represses FLC</data>
      <data key="edge_doi">10.1534/genetics.104.036533</data>
      <data key="edge_evidence">FLC is also negatively regulated by the autonomous pathway</data>
    </edge>
    <edge id="e15" source="FPA" target="FLC">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">FPA autonomous-pathway RBP represses FLC</data>
      <data key="edge_doi">10.1534/genetics.104.036533</data>
      <data key="edge_evidence">FLC is also negatively regulated by the autonomous pathway</data>
    </edge>
    <edge id="e16" source="FLD" target="FLC">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">FLD autonomous-pathway H3K4 demethylase represses FLC</data>
      <data key="edge_doi">10.1199/tab.0171</data>
      <data key="edge_evidence">Mutations in autonomous pathway genes result in high level of FLC expression</data>
    </edge>
    <edge id="e17" source="FVE" target="FLC">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">FVE recruits HDA6 to FLC</data>
      <data key="edge_doi">10.4161/psb.27342</data>
      <data key="edge_evidence">HOS1 physically interacts with FVE, and FVE is essential for the binding of HOS1 to FLC chromatin</data>
    </edge>
    <edge id="e18" source="LD" target="FLC">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">LD is a homeodomain-containing transcriptional repressor of FLC; interacts with FLD and SDG26 in autonomous pathway complex</data>
      <data key="edge_doi">10.1093/nar/gkac551</data>
      <data key="edge_evidence">LD is a homeodomain-containing protein that functions as a transcriptional repressor of FLC; SDG26 interacts with the autonomous pathway components LD and FLD and thereby forms a complex that promotes flowering by suppressing FLC expression.</data>
    </edge>
    <edge id="e19" source="FLC" target="FT">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">FLC-SVP heterodimer binds first intron of FT and represses transcription</data>
      <data key="edge_doi">10.1016/j.xplc.2023.100552</data>
      <data key="edge_evidence">SVP-FLC, SVP-FLM, FLC-FLM heterodimers bind to the first intron of FT</data>
    </edge>
    <edge id="e20" source="FLC" target="SOC1">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">FLC binds SOC1 promoter and represses it; cdf1235 mutation relieves this to increase SOC1</data>
      <data key="edge_doi">10.1111/tpj.12759</data>
      <data key="edge_evidence">FT, SUPPRESSOR OF OVEREXPRESSION OF CONSTANS 1 (SOC1) and FRUITFULL (FUL)</data>
    </edge>
    <edge id="e21" source="SVP" target="FT">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">SVP-FLC, SVP-FLM heterodimers bind first intron of FT and repress transcription</data>
      <data key="edge_doi">10.1016/j.xplc.2023.100552</data>
      <data key="edge_evidence">SVP-FLC, SVP-FLM, FLC-FLM heterodimers bind to the first intron of FT</data>
    </edge>
    <edge id="e22" source="SVP" target="SOC1">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">SVP binds SOC1 regulatory sequences directly, often as a complex with FLC</data>
      <data key="edge_doi">10.1104/pp.112.202614</data>
      <data key="edge_evidence">SVP binds SOC1 regulatory sequences as well</data>
    </edge>
    <edge id="e23" source="Warm_Temperature" target="SVP">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Warm ambient temperature triggers rapid SVP protein degradation via the 26S proteasome pathway</data>
      <data key="edge_doi">10.3390/ijms19103196</data>
      <data key="edge_evidence">SVP protein is rapidly degraded by the 26S proteasome pathway in response to warm ambient temperatures</data>
    </edge>
    <edge id="e24" source="Warm_Temperature" target="PIF4">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Warm temperature releases ELF3/HY5 repression and stabilizes PIF4 via reduced phyB activity</data>
      <data key="edge_doi">10.3390/ijms19103196</data>
      <data key="edge_evidence">Warm temperatures reduce the binding of the evening complex to chromatin and eventually promotes the expression of PIF4</data>
    </edge>
    <edge id="e25" source="PIF4" target="FT">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">PIF4 binds Block E region of FT promoter</data>
      <data key="edge_doi">10.1016/j.xplc.2023.100552</data>
      <data key="edge_evidence">PIF4 binds Block E region</data>
    </edge>
    <edge id="e26" source="GA20OX" target="Gibberellin">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">GA20ox catalyzes the penultimate step in bioactive GA production</data>
      <data key="edge_doi">10.1199/tab.0103</data>
      <data key="edge_evidence">Overexpression of GA20ox: early flowering and increased stem growth phenotypes</data>
    </edge>
    <edge id="e27" source="Gibberellin" target="GID1">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Bioactive GA binds the GID1 receptor, enabling GID1 to interact with DELLA proteins</data>
      <data key="edge_doi">10.1199/tab.0103</data>
