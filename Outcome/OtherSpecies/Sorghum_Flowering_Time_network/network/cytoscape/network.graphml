      <data key="edge_doi">10.1080/15592324.2016.1261232</data>
      <data key="edge_evidence">In Arabidopsis, FT together with SUPPRESSOR OF OVEREXPRESSION OF CONSTANS (SOC1), promotes expression of meristem identity gene LFY and AP1, leading to floral transition.</data>
    </edge>
    <edge id="e59" source="FT8" target="SOC1">
