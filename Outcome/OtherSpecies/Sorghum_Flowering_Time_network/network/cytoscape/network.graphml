      <data key="edge_doi">10.1371/journal.pone.0105352</data>
      <data key="edge_evidence">SbPRR37 and SbGHD7 repress expression of...SbCN8.</data>
    </edge>
    <edge id="e42" source="PRR37" target="FT10">
      <data key="edge_sign">negative</data>
