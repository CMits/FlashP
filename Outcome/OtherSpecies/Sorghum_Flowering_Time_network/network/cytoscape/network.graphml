    <edge id="e71" source="FT1" target="Flowering_Time">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">SbFT1 florigen promotes the vegetative-to-reproductive transition in the shoot apical meristem, reducing days to flowering.</data>
      <data key="edge_doi">10.1111/nph.13834</data>
      <data key="edge_evidence">three genes...activate flowering in transgenic Arabidopsis plants, suggesting florigenic potential.</data>
    </edge>
    <edge id="e72" source="FT8" target="Flowering_Time">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">SbFT8 florigen accelerates flowering transition.</data>
      <data key="edge_doi">10.1111/nph.19591</data>
      <data key="edge_evidence">SbEhd1OE activated the promoters of three functional florigens (SbFT1, SbFT8 and SbFT10), dramatically accelerating flowering.</data>
    </edge>
    <edge id="e73" source="FT10" target="Flowering_Time">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">SbFT10 is the major florigen in sorghum (directly repressed by Ghd7); promotes flowering transition.</data>
      <data key="edge_doi">10.1111/nph.19591</data>
      <data key="edge_evidence">repressing transcription of the major florigen FLOWERING LOCUS T 10 (SbFT10).</data>
    </edge>
    <edge id="e74" source="FT12" target="Flowering_Time">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">SbFT12 (Sb06g012260, FlrAvgD1, panicoid-specific PEBP) is a floral suppressor; loss-of-function confers photoperiod-insensitive early flowering. Reduction-of-function at CAAT-box deletion in 5'UTR drove temperate adaptation.</data>
      <data key="edge_doi">10.1093/molbev/msw120</data>
      <data key="edge_evidence">wild-type Sb06g012260 is a floral suppressor.</data>
    </edge>
    <edge id="e75" source="AP2" target="Flowering_Time">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">SbAP2 (Sobic.001G036800, rap2.7-ortholog) represses flowering; loss (via miR172) relieves repression.</data>
      <data key="edge_doi">10.1111/tpj.70250</data>
      <data key="edge_evidence">ortholog of the maize gene rap2.7 which acts as a negative regulator of flowering time.</data>
    </edge>
