    <edge id="e0" source="Strigolactone" target="D14">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">SL binds D14 alpha/beta hydrolase, induces conformational change and formation of D14-D3-D53 complex</data>
      <data key="edge_doi">10.1038/nature12870</data>
      <data key="edge_evidence">D53 was shown to interact with D14 by pull-down assay. Interaction enhanced by GR24 in a dose-dependent manner.</data>
    </edge>
    <edge id="e1" source="D14" target="D53">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">D14 recruits SCF-D3 E3 ligase to ubiquitinate D53 for 26S proteasomal degradation</data>
      <data key="edge_doi">10.1038/nature12870</data>
      <data key="edge_evidence">D53 protein levels decreased rapidly upon GR24 treatment in wild-type seedlings. Mutations at Ser-His-Asp catalytic triad could attenuate the SL-induced degradation of D53.</data>
    </edge>
    <edge id="e2" source="D3" target="D53">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">D3 is the F-box subunit of SCF complex that ubiquitinates D53; required for proteasomal degradation</data>
      <data key="edge_doi">10.1038/nature12878</data>
      <data key="edge_evidence">SLs induce D53 degradation by the proteasome and abrogate its activity in promoting axillary bud outgrowth, in a D14- and D3-dependent manner.</data>
    </edge>
    <edge id="e3" source="D53" target="IPA1">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">D53 binds IPA1 via direct protein-protein interaction and represses IPA1 transcriptional activation activity</data>
      <data key="edge_doi">10.1038/cr.2017.102</data>
      <data key="edge_evidence">D53 physically interacts with IPA1 in vivo and in vitro and suppresses the transcriptional activation activity of IPA1.</data>
    </edge>
    <edge id="e4" source="D53" target="MOC1">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">D53 physically interacts with MOC1 to repress tiller bud outgrowth</data>
      <data key="edge_doi">10.1038/s41477-019-0376-1</data>
      <data key="edge_evidence">D53 interacts with MOC1 to repress MOC1 activity in tiller regulation.</data>
    </edge>
    <edge id="e5" source="D53" target="CKX9">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">D53 represses OsCKX9 expression; SL-induced D53 degradation derepresses OsCKX9</data>
      <data key="edge_doi">10.1073/pnas.1810980116</data>
      <data key="edge_evidence">D53 represses OsCKX9; knockdown of D53 increases OsCKX9 expression.</data>
    </edge>
    <edge id="e6" source="IPA1" target="TB1">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">IPA1 directly binds GTAC motif in OsTB1 promoter via SBP domain and activates transcription</data>
      <data key="edge_doi">10.1105/tpc.113.113639</data>
      <data key="edge_evidence">IPA1 could directly bind to the promoter of rice TEOSINTE BRANCHED1 via GTAC motif binding to suppress rice tillering.</data>
    </edge>
    <edge id="e7" source="IPA1" target="D53">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">IPA1 directly binds GTAC element in D53 promoter and activates D53 transcription (negative feedback loop with D53 protein repressing IPA1)</data>
      <data key="edge_doi">10.1038/cr.2017.102</data>
      <data key="edge_evidence">IPA1 directly binds D53 promoter GTAC element and activates D53 transcription, forming negative feedback loop.</data>
    </edge>
    <edge id="e8" source="IPA1" target="PIN1B">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">IPA1 directly binds OsPIN1b promoter to activate auxin efflux carrier expression</data>
      <data key="edge_doi">10.1105/tpc.113.113639</data>
      <data key="edge_evidence">EMSA confirmed IPA1 could directly target PIN1b promoter.</data>
    </edge>
    <edge id="e9" source="miR156" target="IPA1">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">OsmiR156 cleaves IPA1/OsSPL14 mRNA via miR156 recognition site in 3' region</data>
      <data key="edge_doi">10.1038/ng.591</data>
      <data key="edge_evidence">One nucleotide substitution in the OsmiR156 recognition site perturbs OsmiR156-directed mRNA degradation; accumulation of OsSPL14 leads to ideal plant architecture.</data>
    </edge>
    <edge id="e10" source="IPI1" target="IPA1">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">IPI1 stabilises OsSPL14/IPA1 protein in shoot apex via K63-linked polyubiquitination (tissue-specific: degrades in panicle but stabilises in shoot); ipi1-CRISPR -&gt; reduced IPA1 accumulation -&gt; increased tillering</data>
      <data key="edge_doi">10.1105/tpc.16.00879</data>
      <data key="edge_evidence">ipi1-1 CRISPR mutant showed reduced IPA1 accumulation in the shoot apex and an increased tiller phenotype, supporting that IPI1 stabilises IPA1 in this tissue.</data>
    </edge>
    <edge id="e11" source="SHI1" target="IPA1">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">OsSHI1 physically interacts with IPA1 and reduces IPA1 DNA binding affinity, inhibiting transcriptional activation activity</data>
      <data key="edge_doi">10.1105/tpc.19.00023</data>
      <data key="edge_evidence">OsSHI1 repressed the transcriptional activation activity of IPA1 via physical interaction.</data>
    </edge>
    <edge id="e12" source="D27" target="Strigolactone">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">D27 is iron-containing beta-carotene isomerase, first step of SL biosynthesis converting all-trans to 9-cis-beta-carotene</data>
      <data key="edge_doi">10.1105/tpc.109.065987</data>
      <data key="edge_evidence">2'-epi-5-deoxystrigol was undetectable in d27 vs. wild-type root exudates.</data>
    </edge>
    <edge id="e13" source="D10" target="Strigolactone">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">D10 encodes CAROTENOID CLEAVAGE DIOXYGENASE 8 (CCD8) cleaving 9-cis-beta-apo-10'-carotenal to carlactone</data>
      <data key="edge_doi">10.1111/j.1365-313X.2007.03210.x</data>
      <data key="edge_evidence">D10 encodes a CAROTENOID CLEAVAGE DIOXYGENASE 8 (CCD8) involved in strigolactone biosynthesis.</data>
    </edge>
    <edge id="e14" source="D17" target="Strigolactone">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">D17/HTD1 encodes CCD7 catalyzing cleavage of 9-cis-beta-carotene to 9-cis-beta-apo-10'-carotenal</data>
      <data key="edge_doi">10.1270/jsbbs.22088</data>
      <data key="edge_evidence">D17/HIGH-TILLERING DWARF1 (HTD1) acts as enzyme in SL biosynthesis; rice D17 encodes CCD7.</data>
    </edge>
    <edge id="e15" source="MAX1" target="Strigolactone">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Rice MAX1 homologs (Os900, Os1400, Os1500, Os1900, Os5100) convert carlactone to 4-deoxyorobanchol</data>
      <data key="edge_doi">10.1073/pnas.1314805111</data>
      <data key="edge_evidence">Rice MAX1 (Os900) and other homologs convert carlactone to 4-deoxyorobanchol (4DO).</data>
    </edge>
    <edge id="e16" source="TB1" target="Tiller_Number">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
