      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Decapitation removes apical auxin source, releasing axillary buds from apical dominance</data>
      <data key="edge_doi">10.1038/nature12954</data>
      <data key="edge_evidence">Decapitation removes apical auxin source; rapid sugar flux precedes auxin depletion at buds.</data>
    </edge>
    <edge id="e63" source="Nitrogen" target="D10">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">N sufficiency represses SL biosynthesis genes D10, D17, D27</data>
      <data key="edge_doi">10.1016/j.plantsci.2018.02.020</data>
      <data key="edge_evidence">N-deficient conditions upregulate D10, D17, D27; high N represses them.</data>
    </edge>
    <edge id="e64" source="Nitrogen" target="D17">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">N sufficiency represses D17/HTD1 SL biosynthesis</data>
      <data key="edge_doi">10.1016/j.plantsci.2018.02.020</data>
      <data key="edge_evidence">N-deficient conditions upregulate D17; high N represses.</data>
    </edge>
    <edge id="e65" source="Nitrogen" target="D27">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">N sufficiency represses D27 SL biosynthesis</data>
      <data key="edge_doi">10.1016/j.plantsci.2018.02.020</data>
      <data key="edge_evidence">N-deficient conditions upregulate D27; high N represses.</data>
    </edge>
    <edge id="e66" source="Light" target="CCA1">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Light signal entrains OsCCA1 expression (canonical circadian clock input)</data>
      <data key="edge_doi">10.1105/tpc.20.00289</data>
      <data key="edge_evidence">OsCCA1 shows morning-peak circadian expression entrained by light, and integrates sugar signaling in tiller regulation.</data>
    </edge>
    <edge id="e67" source="Photoperiod" target="PRR1">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Photoperiod regulates OsPRR1 evening expression</data>
      <data key="edge_doi">10.1105/tpc.20.00289</data>
      <data key="edge_evidence">OsPRR1 evening-peak expression is photoperiod-dependent in rice clock.</data>
    </edge>
    <edge id="e68" source="TAR2" target="Auxin">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">OsTAR2 is TAA/TAR aminotransferase; first step of IAA biosynthesis from tryptophan to IPA</data>
      <data key="edge_doi">10.3389/fpls.2024.1516884</data>
      <data key="edge_evidence">OsTAR2 catalyzes the first step of tryptophan-dependent IAA biosynthesis in rice.</data>
    </edge>
    <edge id="e69" source="YUCCA" target="Auxin">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">OsYUCCA enzymes catalyze rate-limiting step of IAA biosynthesis (IPA to IAA)</data>
      <data key="edge_doi">10.3389/fpls.2024.1516884</data>
      <data key="edge_evidence">OsYUCCAs are rate-limiting enzymes in auxin synthesis; multiple members contribute to tiller angle and architecture.</data>
    </edge>
    <edge id="e70" source="MOC1" target="LAX1">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">MOC1 positively affects axillary meristem gene network including LAX1</data>
      <data key="edge_doi">10.1105/tpc.108.065425</data>
      <data key="edge_evidence">MOC1 works together with LAX1 in axillary meristem formation; lax1 moc1 double mutant shows enhanced AM suppression.</data>
    </edge>
    <edge id="e71" source="Sucrose" target="T6P">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Sucrose synthesis generates trehalose-6-phosphate (T6P) signaling molecule</data>
      <data key="edge_doi">10.1111/nph.18000</data>
      <data key="edge_evidence">Mounting evidence indicates that sucrose effects on branching are mediated by trehalose-6-phosphate (T6P).</data>
    </edge>
    <edge id="e72" source="T6P" target="TB1">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">T6P signaling represses BRC1/OsTB1 expression</data>
      <data key="edge_doi">10.1111/nph.18000</data>
      <data key="edge_evidence">Sucrose/T6P signaling partially represses PsBRC1 (OsTB1 ortholog) expression in peripheral buds.</data>
    </edge>
    <edge id="e73" source="NRT1_1B" target="NGR5">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">NRT1.1B-dependent phosphorylation promotes NGR5 stability (nitrate-sensing-to-chromatin)</data>
      <data key="edge_doi">10.1038/ng.3337</data>
      <data key="edge_evidence">NRT1.1B natural variation in indica enhances N uptake signaling that converges on NGR5 activity.</data>
    </edge>
    <edge id="e74" source="GA20OX2" target="Gibberellin">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">OsGA20ox2 (SD1) catalyzes multiple oxidation steps in GA biosynthesis</data>
      <data key="edge_doi">10.1038/416701a</data>
      <data key="edge_evidence">sd1 allele is a null mutation in GA20ox2; sd1 plants have reduced GA levels.</data>
    </edge>
    <edge id="e75" source="RR_TYPEA" target="Cytokinin">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Type-A OsRRs provide negative feedback on CK signaling</data>
      <data key="edge_doi">10.1104/pp.111.192765</data>
      <data key="edge_evidence">Type-A OsRRs act as negative regulators of CK signaling (classical feedback).</data>
    </edge>
    <edge id="e76" source="Brassinosteroid" target="DLT">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">BR signaling activates DLT expression/function in tiller promotion</data>
      <data key="edge_doi">10.1111/j.1365-313X.2009.03825.x</data>
      <data key="edge_evidence">DLT plays positive roles in brassinosteroid signaling in rice; BR pathway activates DLT.</data>
    </edge>
    <edge id="e77" source="NGR5" target="IPA1">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">NGR5 binds IPA1/OsSPL14 promoter and recruits PRC2 complex to deposit H3K27me3 mark; ChIP-qPCR direct binding confirmed; nitrogen dose-dependent</data>
      <data key="edge_doi">10.1126/science.aaz2046</data>
      <data key="edge_evidence">ChIP-qPCR analysis showed that NGR5 can directly bind to the promoter region of D14 and SPL14, and the binding strength increased with increasing nitrogen concentration.</data>
    </edge>
    <edge id="e78" source="Sucrose" target="NGR5">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Photosynthesis-derived sucrose activates NGR5 expression at the shoot base, providing carbon-nitrogen integration for tiller bud elongation</data>
      <data key="edge_doi">10.1111/nph.19921</data>
      <data key="edge_evidence">The expression of nitrogen-mediated tiller growth response 5 (NGR5) was remarkably decreased in shoot base of dtn1-2, which can be activated by sucrose treatment.</data>
    </edge>
    <edge id="e79" source="DTN1" target="Sucrose">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">DTN1 (Decreased Tiller Number 1) encodes fructose-1,6-bisphosphate aldolase and is required for photosynthesis and sucrose accumulation in shoot base / axillary buds</data>
      <data key="edge_doi">10.1111/nph.19921</data>
      <data key="edge_evidence">Deficiency of DTN1 results in reduced photosynthetic rate and decreased contents of sucrose and other sugars in both leaves and axillary buds.</data>
    </edge>
    <edge id="e80" source="VIL2" target="TB1">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">OsVIL2 chromatin-interacting factor binds OsTB1 promoter and represses OsTB1 expression via chromatin modification, releasing axillary bud outgrowth</data>
      <data key="edge_doi">10.14348/molcells.2019.0141</data>
      <data key="edge_evidence">Expression of OsTB1 was increased in osvil2 mutants. ChIP assays showed that OsVIL2 binds to the promoter region of OsTB1 in wild-type rice; tiller number of double mutant osvil2 ostb1 was similar to that of ostb1 (osvil2 epistatic to ostb1).</data>
    </edge>
    <edge id="e81" source="GATA8" target="TCP19">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">OsGATA8 transcription factor represses OsTCP19 (negative regulator of tillering), promoting productive tiller formation under N-replete conditions</data>
      <data key="edge_doi">10.1038/s41588-024-01795-7</data>
      <data key="edge_evidence">OsGATA8 promotes tiller formation by repressing the transcription of OsTCP19, a negative modulator of tillering.</data>
    </edge>
    <edge id="e82" source="MAX1_1900" target="Strigolactone">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Os1900 (one of five rice MAX1-like paralogs) catalyzes carlactone-to-carlactonoic acid conversion together with Os5100; Os1900 is the N-fertilization-responsive paralog</data>
      <data key="edge_doi">10.1038/s41467-023-38670-8</data>
      <data key="edge_evidence">Os1900 together with another MAX1-like gene, Os5100, play a critical role in controlling the conversion of carlactone into carlactonoic acid during strigolactone biosynthesis and tillering in rice.</data>
    </edge>
    <edge id="e83" source="Nitrogen" target="MAX1_1900">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Fertilization (N supply) transcriptionally upregulates Os1900 promoter; promoter mutations that disrupt N-induction increase tiller numbers under low fertilizer</data>
      <data key="edge_doi">10.1038/s41467-023-38670-8</data>
      <data key="edge_evidence">Fertilization controls tiller number in rice through transcriptional regulation of Os1900, and a few promoter mutations alone can increase tiller numbers and grain yields even under minor-fertilizer conditions.</data>
    </edge>
    <edge id="e84" source="MOC1" target="MOC3">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">MOC1 physically interacts with MOC3 (OsWUS/TAB1) and acts as a transcriptional co-activator; MOC1 cannot bind FON1 promoter alone but cooperates with MOC3 binding</data>
      <data key="edge_doi">10.1016/j.molp.2019.04.011</data>
      <data key="edge_evidence">MOC3 is able to directly bind the promoter of FON1 and subsequently activate FON1 expression, while MOC1 functions as a co-activator of MOC3 but could not directly bind the FON1 promoter.</data>
    </edge>
    <edge id="e85" source="T20" target="Strigolactone">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">T20 encodes Î¶-carotene isomerase (Z-ISO) acting upstream of D27 in the carotenoid pathway; required for SL precursor supply</data>
      <data key="edge_doi">10.1016/j.molp.2020.10.001</data>
      <data key="edge_evidence">The T20 gene encodes a chloroplast Î¶-carotene isomerase (Z-ISO), which is involved in the biosynthesis of carotenoids and their metabolites, strigolactone (SL) and abscisic acid (ABA).</data>
    </edge>
    <edge id="e86" source="Gibberellin" target="GID1">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">GA binds GID1 nuclear receptor; GA-GID1 forms the active complex that subsequently recruits SCF-GID2 to ubiquitinate SLR1 and NGR5.</data>
      <data key="edge_doi">10.1038/nature03449</data>
      <data key="edge_evidence">GID1 is a soluble gibberellin receptor; GA-GID1 complex is required for downstream DELLA protein degradation.</data>
    </edge>
    <edge id="e87" source="GID1" target="SLR1">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">GA-GID1 complex promotes SLR1 (rice DELLA) interaction with F-box SCF-GID2 for polyubiquitination and 26S proteasomal degradation.</data>
      <data key="edge_doi">10.1038/nature03449</data>
      <data key="edge_evidence">GID1 is a soluble GA receptor; GA-GID1 complex promotes SLR1 interaction with F-box SCF-GID2 for degradation.</data>
    </edge>
    <edge id="e88" source="GID1" target="NGR5">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">GA-GID1 complex directly targets NGR5 (Nitrogen-mediated tiller Growth Response 5) for 26S proteasomal degradation, coupling GA signalling to N-responsive tiller-promoting transcription.</data>
      <data key="edge_doi">10.1126/science.aaz2046</data>
      <data key="edge_evidence">GA receptor GID1 targets NGR5 for proteolysis by the 26S proteasome.</data>
    </edge>
    <edge id="e89" source="Auxin" target="TIR1">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Auxin (IAA) binds the TIR1/OsAFB F-box receptor in the SCF-TIR1 complex; IAA-TIR1 then ubiquitinates OsIAA repressors for proteasomal degradation. Represented as activating edge onto TIR1 to gate all auxin transcriptional effects.</data>
      <data key="edge_doi">10.3389/fpls.2024.1516884</data>
      <data key="edge_evidence">TIR1/OsAFB family members are auxin receptors that exhibit partial redundancy in regulating yield, tillering, and plant height.</data>
    </edge>
    <edge id="e90" source="TIR1" target="D10">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Summary edge: active TIR1 derepresses OsIAA-OsARF axis; derepressed OsARFs bind D10 (CCD8) promoter to promote SL biosynthesis gene transcription. Collapsed through TIR1 to avoid proliferating OsIAA/OsARF intermediates that the curated set does not fully specify.</data>
      <data key="edge_doi">10.3389/fpls.2024.1516884</data>
      <data key="edge_evidence">Auxin-TIR1 signalling promotes expression of SL biosynthesis genes (D10, D17) through OsARF-mediated transcription.</data>
    </edge>
    <edge id="e91" source="TIR1" target="D17">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Summary edge: active TIR1 derepresses OsIAA-OsARF; OsARFs activate D17 (CCD7, HTD1) transcription. Auxin's SL-biosynthesis upregulation routed through TIR1 to preserve Perception Gate purity.</data>
      <data key="edge_doi">10.3389/fpls.2024.1516884</data>
      <data key="edge_evidence">Auxin-TIR1 signalling promotes SL biosynthesis gene transcription including D17.</data>
    </edge>
    <edge id="e92" source="TIR1" target="IPT">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Summary edge: active TIR1 degrades OsIAA, releasing OsARFs; auxin-responsive OsARFs repress IPT (CK biosynthesis) transcription. Classic apical-auxin-represses-CK-biosynthesis mechanism routed through TIR1.</data>
      <data key="edge_doi">10.3389/fpls.2024.1516884</data>
      <data key="edge_evidence">Apical auxin represses cytokinin biosynthesis by inhibiting IPT through TIR1-dependent signalling.</data>
    </edge>
    <edge id="e93" source="AHP" target="RR_TYPEA">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Canonical two-component phosphorelay: AHP (histidine phosphotransfer) phosphorylates type-A RRs, which accumulate as primary CK-response transcriptional targets. Replaces direct Cytokinin-&gt;RR_TYPEA bypass.</data>
      <data key="edge_doi">10.1104/pp.111.192765</data>
      <data key="edge_evidence">Most type-A OsRR genes are rapidly upregulated by cytokinin (peak 30-60 min) via the AHP-RR phosphorelay.</data>
    </edge>
    <edge id="e94" source="IPA1" target="LOG">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">IPA1 directly binds OsLOG promoter and first intron to activate LOG (cytokinin-activating enzyme / lonely guy) transcription.</data>
      <data key="edge_doi">10.1105/tpc.113.113639</data>
      <data key="edge_evidence">EMSA assays confirmed that IPA1 could directly target the promoter or first intron of LOG.</data>
    </edge>
    <edge id="e95" source="IPA1" target="HK4">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">IPA1 activates OsHK4 via binding TGGGCC motif in its promoter with TCP co-factors PCF1/PCF2; forms IPA1-HK4 positive feedback arm of CK signalling.</data>
      <data key="edge_doi">10.1093/plcell/koad257</data>
      <data key="edge_evidence">IPA1 upregulates expression through interactions with two TCP transcription factors, binding TGGGCC motifs in the OsHK4 promoter via PCF1/PCF2 heterotrimers.</data>
    </edge>
    <edge id="e96" source="HOX12" target="NCED1">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">HOX12 homeodomain-leucine-zipper TF directly induces OsNCED1 expression to drive ABA biosynthesis in shoot base; part of SL-induced parallel ABA-mediated tillering-repression arm.</data>
      <data key="edge_doi">10.1016/j.molp.2020.10.001</data>
      <data key="edge_evidence">rac-GR24 stimulated expression of OsNCED1 through induction of HOX12, promoting ABA biosynthesis in shoot base.</data>
    </edge>
    <edge id="e97" source="NCED1" target="ABA">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">OsNCED1 (9-cis-epoxycarotenoid dioxygenase 1) catalyses the rate-limiting cleavage of 9-cis-xanthophyll to xanthoxin in ABA biosynthesis.</data>
      <data key="edge_doi">10.1016/j.molp.2020.10.001</data>
      <data key="edge_evidence">NCED1 encodes an ABA biosynthesis enzyme; HOX12 directly transactivates OsNCED1 promoter driving ABA production that negatively regulates tillering.</data>
    </edge>
    <edge id="e98" source="ABA" target="D10">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">ABA represses SL biosynthesis genes including D10 (and D17, D27) via transcriptional downregulation; ABA biosynthetic mutants (aba1, aba2) show elevated SL biosynthesis, producing negative ABA-to-SL feedback.</data>
      <data key="edge_doi">10.1016/j.molp.2020.10.001</data>
      <data key="edge_evidence">ABA treatment significantly repressed SL biosynthesis and ABA biosynthetic mutants displayed elevated SL biosynthesis.</data>
    </edge>
    <edge id="e99" source="HK4" target="TB1">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">OsHK4 CK receptor phosphorelay activates B-type response regulator OsRR21 which binds OsTB1 promoter and represses transcription in axillary meristem; ohk4 LOF de-represses OsTB1 -&gt; reduced tillering</data>
      <data key="edge_doi">10.1093/plcell/koad257</data>
      <data key="edge_evidence">ohk4 mutants exhibited reduced tiller numbers and de-repressed OsTB1 expression in axillary meristems; OsHK4 signalling through type-B response regulators represses OsTB1 transcription.</data>
    </edge>
  </graph>
</graphml>