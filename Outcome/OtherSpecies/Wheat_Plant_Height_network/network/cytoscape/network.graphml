      <data key="edge_doi">10.1093/aob/mcy218</data>
      <data key="edge_evidence">HB33 expression which negatively responded to ABA, and reduced root length and plant height by repressing expression of Gretchen Hagen 3 (GH3) genes</data>
    </edge>
    <edge id="e44" source="TAGH3" target="Auxin">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
