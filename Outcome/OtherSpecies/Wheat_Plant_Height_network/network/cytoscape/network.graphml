      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Ppd-1 is a pseudo-response regulator entrained by day length; long-day activates Ppd-1.</data>
      <data key="edge_doi">10.3389/fpls.2018.01312</data>
