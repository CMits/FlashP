      <data key="edge_doi">10.1093/aob/mcy218</data>
      <data key="edge_evidence">repressing expression of Gretchen Hagen 3 (GH3) genes</data>
    </edge>
    <edge id="e45" source="Vernalization" target="VRN1">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
