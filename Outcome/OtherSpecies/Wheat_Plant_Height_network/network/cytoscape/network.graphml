      <data key="edge_doi">10.1073/pnas.2209875119</data>
      <data key="edge_evidence">autoactivation of Rht13 leads to upregulation of pathogenesis-related (PR) genes, including class III peroxidases</data>
    </edge>
    <edge id="e49" source="Pathogenesis_Related_Genes" target="Plant_Height">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Class-III peroxidases cross-link cell-wall compounds, limiting elongation and reducing height.</data>
      <data key="edge_doi">10.1073/pnas.2209875119</data>
      <data key="edge_evidence">class III peroxidases, which may catalyse the cross-linking of cell wall compounds to limit cell elongation and hence reduce height</data>
    </edge>
    <edge id="e50" source="TAOSCA1_4" target="Plant_Height">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">TaOSCA1.4 hyperosmolality-gated Ca2+ channel; RNAi reduces height 11-16% via GA-independent route.</data>
      <data key="edge_doi">10.3389/fpls.2024.1381243</data>
      <data key="edge_evidence">the average PHs of the wild-type (WT), RNAi lines 1 (Ri-1) and 2 (Ri-2) were 94.6, 83.6 and 79.2 cm, respectively</data>
