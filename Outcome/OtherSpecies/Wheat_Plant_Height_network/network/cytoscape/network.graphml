    <edge id="e0" source="TAGA20OX" target="Gibberellin">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">GA 20-oxidase catalyses GA12→GA9 and GA53→GA20; rate-limiting late GA biosynthesis.</data>
      <data key="edge_doi">10.1007/s00425-005-0104-0</data>
      <data key="edge_evidence">GA 20-oxidase and 3-oxidase are major sites of regulation in GA biosynthesis; enzymes catalyze multi-step reactions, including conversions of GA12-GA9, and GA53-GA20</data>
    </edge>
    <edge id="e1" source="TAGA3OX" target="Gibberellin">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">GA 3-oxidase catalyses 3β-hydroxylation GA20→GA1 producing bioactive GA.</data>
      <data key="edge_doi">10.1093/jxb/eraf151</data>
      <data key="edge_evidence">GA3OX3 catalyses the 3β-hydroxylation of GA20 to GA1</data>
    </edge>
    <edge id="e2" source="TAGA2OX" target="Gibberellin">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">GA 2-oxidase catabolises bioactive GA1/GA4 to inactive GA8/GA34.</data>
      <data key="edge_doi">10.1104/pp.18.00023</data>
      <data key="edge_evidence">increased expression of GA2oxA9 in Rht18 results in a reduction of both bioactive GA content and plant height</data>
    </edge>
    <edge id="e3" source="TAGA1OX1" target="Gibberellin">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">TaGA1ox1 1β-hydroxylates GA9/GA20 to inactive GA61/GA60, diverting from bioactive pool.</data>
      <data key="edge_doi">10.1093/jxb/eraf151</data>
      <data key="edge_evidence">ga1ox1 Mutant: Bioactive GA1/GA4 extremely high; 10.7 cm taller in 2021 field trial</data>
    </edge>
    <edge id="e4" source="RHT8" target="Gibberellin">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Rht8 (TaRNHL-D1) promotes bioactive GA biosynthesis in stem.</data>
      <data key="edge_doi">10.1016/j.molp.2022.01.014</data>
      <data key="edge_evidence">controls the plant height and spike length via GA biosynthesis</data>
    </edge>
    <edge id="e5" source="Nitrogen" target="Gibberellin">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Nitrate signalling activates GA metabolism gene expression, raising bioactive GA.</data>
      <data key="edge_doi">10.1016/j.cub.2021.09.024</data>
      <data key="edge_evidence">nitrate reduces the abundance of DELLAs by increasing GA contents through activation of GA metabolism gene expression</data>
    </edge>
    <edge id="e6" source="Gibberellin" target="TAGA2OX">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">GA induces its own catabolism — classic GA homeostasis (GA→TaGA2ox↑→GA↓).</data>
      <data key="edge_doi">10.7717/peerj.15924</data>
      <data key="edge_evidence">exogenous GA3 increases the expressions of GA2oxs</data>
    </edge>
    <edge id="e7" source="VRN1" target="TAGA20OX">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">VRN1 binds and activates the TaGA20ox2 promoter, coupling vernalization to GA biosynthesis.</data>
      <data key="edge_doi">10.1016/j.xplc.2025.101325</data>
      <data key="edge_evidence">VRN1 binds to and activates the TaGA20ox2 promoter</data>
    </edge>
    <edge id="e8" source="RHT_B1" target="TAGA20OX">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">DELLA promotes TaGA20ox transcription (negative-feedback GA homeostasis: DELLA↑→GA↑→DELLA↓).</data>
      <data key="edge_doi">10.7717/peerj.15924</data>
      <data key="edge_evidence">DELLA protein signaling alters GA oxidase gene transcription through GA-GID1-DELLA tricomplex</data>
    </edge>
    <edge id="e9" source="RHT18" target="TAGA2OX">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Rht18 allele drives ~4-fold upregulation of TaGA2ox-A9, increasing GA catabolism.</data>
      <data key="edge_doi">10.1104/pp.18.00023</data>
      <data key="edge_evidence">Expression of GA2oxA9 was ~4-fold higher in the Icaro and the M24 overgrowth mutant compared to the tall parent Anhinga</data>
    </edge>
    <edge id="e10" source="RHT24" target="TAGA2OX">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Rht24b cis-regulatory variant elevates TaGA2ox-A9 expression in stems.</data>
      <data key="edge_doi">10.1111/nph.17808</data>
      <data key="edge_evidence">Rht24b conferred higher expression of TaGA2ox-A9 in stems, leading to a reduction of bioactive GA in stems</data>
    </edge>
    <edge id="e11" source="RHT12" target="TAGA2OX">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Rht12b SNP-390(C/A) elevates TaGA2oxA13 expression; causal variant of the Rht12 locus.</data>
      <data key="edge_doi">10.1007/s00122-023-04502-y</data>
      <data key="edge_evidence">Rht12b conferred higher expression level of TaGA2oxA13, and transient activation assays defined SNP-390(C/A) in the promoter of TaGA2oxA13 as the causal variation</data>
    </edge>
    <edge id="e12" source="Gibberellin" target="TAGID1">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">GA binding in the TaGID1 pocket induces conformational change enabling DELLA interaction.</data>
      <data key="edge_doi">10.1104/pp.111.183657</data>
      <data key="edge_evidence">Binding of bioactive GAs within a pocket in the GID1 protein induces a conformational change that permits interaction between the DELLA and GID1 proteins</data>
    </edge>
    <edge id="e13" source="TAGID1" target="RHT_B1">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">GA-bound TaGID1 binds Rht-B1 DELLA N-terminal motif, recruiting SCF-SLY1 for ubiquitination.</data>
      <data key="edge_doi">10.1104/pp.111.183657</data>
      <data key="edge_evidence">This leads to closing of the N-terminal lid of GID1, allowing DELLAs to bind through their conserved N-terminal DELLA/TVHYNP motifs</data>
    </edge>
    <edge id="e14" source="TAGID1" target="RHT_D1">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">GA-bound TaGID1 binds Rht-D1 DELLA homeolog for SCF-SLY1-mediated degradation.</data>
      <data key="edge_doi">10.1016/j.jplph.2012.11.010</data>
      <data key="edge_evidence">Strong interactions between each putative TaGID1 and the wheat DELLA proteins RHT-A1, RHT-B1, and RHT-D1 in the presence of GA3</data>
    </edge>
    <edge id="e15" source="TASLY1" target="RHT_B1">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">SCF-TaSLY1 F-box ubiquitinates Rht-B1 DELLA for 26S proteasomal degradation.</data>
      <data key="edge_doi">10.1104/pp.111.183657</data>
      <data key="edge_evidence">GID1/DELLA binding enables recognition by the GID2/SLEEPY1 F-box component of an SCF Ub E3 ligase, leading to ubiquitination of DELLAs and their subsequent 26S proteasome-mediated degradation</data>
    </edge>
    <edge id="e16" source="TASLY1" target="RHT_D1">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">SCF-TaSLY1 ubiquitinates Rht-D1 DELLA homeolog (parallel to Rht-B1).</data>
      <data key="edge_doi">10.1104/pp.111.183657</data>
      <data key="edge_evidence">GID1/DELLA binding enables recognition by the GID2/SLEEPY1 F-box component of an SCF Ub E3 ligase, leading to ubiquitination of DELLAs</data>
    </edge>
    <edge id="e17" source="Nitrogen" target="RHT_B1">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Nitrate promotes GA-mediated destabilisation of DELLA (partial rescue by global-della mutant).</data>
      <data key="edge_doi">10.1016/j.cub.2021.09.024</data>
      <data key="edge_evidence">the growth restraint conferred by nitrate deficiency is partially rescued in global-DELLA mutant</data>
    </edge>
    <edge id="e18" source="RHT_B1" target="Plant_Height">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Rht-B1 DELLA represses GA-responsive growth; Rht-B1b reduces height ~20%, Rht-B1c ~50%.</data>
      <data key="edge_doi">10.1104/pp.111.183657</data>
      <data key="edge_evidence">DELLA proteins, which act to repress GA-responsive growth, and their mutant alleles Rht-B1b and Rht-D1b are thought to confer dwarfism by producing more active forms of these growth repressors</data>
    </edge>
    <edge id="e19" source="RHT_D1" target="Plant_Height">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Rht-D1 DELLA homeolog represses growth; Rht-D1b Green-Revolution dwarfing allele ~20%.</data>
      <data key="edge_doi">10.1104/pp.111.183657</data>
      <data key="edge_evidence">Rht-B1 and Rht-D1 encode DELLA proteins, which act to repress GA-responsive growth</data>
    </edge>
    <edge id="e20" source="RHT_B1" target="PLATZ_A1">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">DELLA GRAS PFYRE subdomain physically binds and sequesters PLATZ-A1 (Y2H + genetics).</data>
      <data key="edge_doi">10.1073/pnas.2300203120</data>
      <data key="edge_evidence">PLATZ-A1 showed a positive interaction with RHT1-GRAS in yeast-two-hybrid assays</data>
    </edge>
    <edge id="e21" source="PLATZ_A1" target="Plant_Height">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">PLATZ-A1 (Rht25) LOF reduces height ~12.7%; OE increases height (causal Rht25 gene).</data>
      <data key="edge_doi">10.1073/pnas.2300203120</data>
      <data key="edge_evidence">Natural and induced loss-of-function mutations in PLATZ-A1 reduce plant height and its overexpression increases plant height, demonstrating that PLATZ-A1 is the causative gene of RHT25</data>
    </edge>
    <edge id="e22" source="RHT_B1" target="PIF">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">DELLA sequesters PIF TFs; accumulated Rht-B1c constitutively blocks PIF activity.</data>
      <data key="edge_doi">10.1093/jxb/ert183</data>
      <data key="edge_evidence">The accumulated mutant protein constitutively blocks phytochrome-interacting factor activity, suppressing cell elongation genes</data>
    </edge>
    <edge id="e23" source="PIF" target="Plant_Height">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">PIFs activate cell-elongation genes; DELLA-sequestration decreases stem elongation.</data>
      <data key="edge_doi">10.1093/jxb/ert183</data>
      <data key="edge_evidence">constitutively blocks phytochrome-interacting factor activity, suppressing cell elongation genes</data>
    </edge>
    <edge id="e24" source="Light" target="PIF">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Red/far-red light via phytochromes targets PIFs for degradation.</data>
      <data key="edge_doi">10.1093/jxb/ert183</data>
      <data key="edge_evidence">phytochrome-interacting factor activity, suppressing cell elongation genes</data>
    </edge>
    <edge id="e25" source="TAERF_A1" target="PIF">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">TaERF-A1 directly binds the TaPIF4 promoter and activates its transcription (EMSA/ChIP).</data>
      <data key="edge_doi">10.1016/j.xplc.2024.101194</data>
      <data key="edge_evidence">TaERF-A1 directly associates with the promoter of TaPIF4 to activate its expression</data>
    </edge>
    <edge id="e26" source="TAD11" target="Brassinosteroid">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">TaD11 (C6-oxidase) catalyses late BR biosynthesis step; tad11-2a reduces endogenous BR.</data>
      <data key="edge_doi">10.1007/s00122-022-04158-0</data>
      <data key="edge_evidence">The tad11-2a-1 mutant displayed dwarfism, smaller grains, sensitivity to 24-epiBL, and reduced endogenous BR contents</data>
    </edge>
    <edge id="e27" source="TADWF4" target="Brassinosteroid">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">TaDWF4 (CYP90B) 22α-hydroxylation of campesterol — rate-limiting BR biosynthesis branch-point.</data>
      <data key="edge_doi">10.1038/s42003-022-03139-9</data>
      <data key="edge_evidence">Manipulating levels of DWF4/CYP90B, the rate-limiting step in the BR synthesis pathway, has been shown to increase yield</data>
    </edge>
    <edge id="e28" source="Brassinosteroid" target="TABRI1">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">BL ligand binds TaBRI1 extracellular domain, activating receptor kinase and downstream cascade.</data>
      <data key="edge_doi">10.1186/s12870-025-06762-w</data>
      <data key="edge_evidence">BR hormones regulate critical developmental traits in wheat through the BRI1 receptor</data>
    </edge>
    <edge id="e29" source="TASERK" target="TABRI1">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">TaSERK (BAK1 co-receptor) heterodimerises with TaBRI1, required for BR perception.</data>
      <data key="edge_doi">10.1371/journal.pone.0153273</data>
      <data key="edge_evidence">TaBRI1 heterodimerizes with the TaSERKs viz. TaSERK1, TaSERK2, TaSERK3, TaSERK4 and TaSERK5</data>
    </edge>
    <edge id="e30" source="TABKI1" target="TABRI1">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">TaBKI1 represses TaBRI1 kinase activity in the BR-off state.</data>
      <data key="edge_doi">10.1038/s41586-023-06023-6</data>
      <data key="edge_evidence">BR signalling repressor BRI1 kinase inhibitor 1 (TaBKI1)</data>
    </edge>
    <edge id="e31" source="TABRI1" target="TABKI1">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Activated TaBRI1 facilitates TaZnF-mediated ubiquitination of TaBKI1 (mutual release loop).</data>
      <data key="edge_doi">10.1038/s41586-023-06023-6</data>
      <data key="edge_evidence">TaBRI1 facilitates the ZnF-TaBKI1 conjugation in response to BR signalling</data>
    </edge>
    <edge id="e32" source="TAZNF" target="TABKI1">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">TaZnF RING E3 ligase ubiquitinates TaBKI1 for proteasomal destruction.</data>
      <data key="edge_doi">10.1038/s41586-023-06023-6</data>
      <data key="edge_evidence">ZnF acts as a BR signalling activator to facilitate proteasomal destruction of the BR signalling repressor BRI1 kinase inhibitor 1 (TaBKI1)</data>
    </edge>
    <edge id="e33" source="TABRI1" target="TABIN2">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">BRI1-BSK-CDG-BSU1 cascade dephosphorylates and inactivates TaBIN2 (GSK3-like kinase).</data>
      <data key="edge_doi">10.1186/s12870-025-06762-w</data>
      <data key="edge_evidence">In BR signaling, transphosphorylation events mediated through BSK1, CDG1 and BIN2 kinases lead to the activation of BSU1 phosphatase, which acts to dephosphorylate and inactivate BIN2, the negative regulator of BR signaling</data>
    </edge>
    <edge id="e34" source="TABIN2" target="TABZR1">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">TaBIN2 phosphorylates TaBZR1/TaBES1, blocking nuclear localisation and DNA binding.</data>
      <data key="edge_doi">10.1186/s12870-025-06762-w</data>
      <data key="edge_evidence">At low BR concentrations, BIN2 phosphorylates two homologous transcription factors, BZR1 and BES1/BZR2, and inhibits their nuclear localization and DNA-binding activity</data>
    </edge>
    <edge id="e35" source="TABZR1" target="Plant_Height">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Dephosphorylated TaBZR1/TaBES1 activates BR-response growth and cell-elongation genes.</data>
      <data key="edge_doi">10.1186/s12870-025-06762-w</data>
      <data key="edge_evidence">The dephosphorylated active transcription factors, BZR1 and BES1/BZR2, can then bind to specific sites on DNA and regulate expression of several genes</data>
    </edge>
    <edge id="e36" source="TABZR1" target="RHT_B1">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">TaBZR1 physically binds DELLA proteins; reciprocal sequestration (BR-GA antagonism).</data>
      <data key="edge_doi">10.1186/s12870-025-06762-w</data>
      <data key="edge_evidence">BRs and GAs co-regulate a large number of common target genes and BZR1 directly interacts with DELLA proteins</data>
    </edge>
    <edge id="e37" source="TABIN2" target="RHT_B1">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">TaBIN2 phosphorylates and stabilises DELLA (when BR low); BR-GA crosstalk.</data>
      <data key="edge_doi">10.1186/s12870-025-06762-w</data>
      <data key="edge_evidence">BRs and GAs co-regulate a large number of common target genes and BZR1 directly interacts with DELLA proteins; Deletions of domains required for BZR1-DELLA interaction abolished the antagonistic effect</data>
    </edge>
    <edge id="e38" source="Auxin" target="TATIR1">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Auxin binds TaTIR1/AFB F-box forming co-receptor with Aux/IAA substrate.</data>
      <data key="edge_doi">10.3389/fpls.2018.01395</data>
      <data key="edge_evidence">When present, auxin promotes the TIR1/AFB-mediated ubiquitin-proteasome-dependent degradation of inhibitory Aux/IAA proteins</data>
    </edge>
    <edge id="e39" source="TATIR1" target="TAIAA">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Auxin-loaded TaTIR1 targets TaAux/IAA proteins for proteasomal degradation.</data>
      <data key="edge_doi">10.3389/fpls.2018.01395</data>
      <data key="edge_evidence">TIR1/AFB-mediated ubiquitin-proteasome-dependent degradation of inhibitory Aux/IAA proteins</data>
    </edge>
    <edge id="e40" source="TAIAA" target="TAARF">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">TaAux/IAA binds and represses TaARF TFs; removal de-represses ARF activity.</data>
      <data key="edge_doi">10.3389/fpls.2018.01395</data>
      <data key="edge_evidence">thereby activating ARF transcription factors</data>
    </edge>
    <edge id="e41" source="TAARF" target="Plant_Height">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">TaARF4-B haplotypes associate with plant height QTL; ARFs activate growth/elongation genes.</data>
      <data key="edge_doi">10.1093/aob/mcy218</data>
      <data key="edge_evidence">TaARF4-B was strongly associated with PH and root depth at the tillering, jointing and grain fill stages</data>
    </edge>
    <edge id="e42" source="TAARF4" target="TAHB33">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">TaARF4-A regulates TaHB33 expression (auxin-response pathway).</data>
      <data key="edge_doi">10.1093/aob/mcy218</data>
      <data key="edge_evidence">TaARF4-A was shown to regulate HB33 expression which negatively responded to ABA, and reduced root length and plant height by repressing expression of Gretchen Hagen 3 (GH3) genes</data>
    </edge>
    <edge id="e43" source="TAHB33" target="TAGH3">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
