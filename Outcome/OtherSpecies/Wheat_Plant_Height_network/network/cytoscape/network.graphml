      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Dominant Ppd-D1a shortens each internode by ~10%, reducing overall plant height.</data>
      <data key="edge_doi">10.3389/fpls.2018.01312</data>
      <data key="edge_evidence">the dominant Ppd-D1a allele decreases plant height in both the dwarf and tall lines, though its effect is much weaker than that of Rht12</data>
    </edge>
