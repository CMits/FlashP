    <edge id="e0" source="PAL1" target="Cinnamate">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">PAL1 deaminates L-phenylalanine to trans-cinnamate, the entry step of phenylpropanoid metabolism</data>
      <data key="edge_doi">10.3389/fpls.2020.00652</data>
      <data key="edge_evidence">PAL catalyzes the initial step of phenylpropanoid biosynthesis</data>
    </edge>
    <edge id="e1" source="C4H1" target="P_Coumarate">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">C4H (CYP73A) hydroxylates cinnamate at the 4-position to produce p-coumarate</data>
      <data key="edge_doi">10.3389/fpls.2020.00652</data>
      <data key="edge_evidence">C4H hydroxylates cinnamate to p-coumarate in the phenylpropanoid pathway</data>
    </edge>
    <edge id="e2" source="PT4CL1" target="P_Coumaroyl_CoA">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">4CL1 activates p-coumarate as its CoA thioester for downstream reactions</data>
      <data key="edge_doi">10.1104/pp.110.159269</data>
      <data key="edge_evidence">4CL catalyses the activation of 4-coumarate to 4-coumaroyl-CoA</data>
    </edge>
    <edge id="e3" source="HCT1" target="P_Coumaroyl_Shikimate">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">HCT transfers p-coumaroyl-CoA onto shikimate to yield p-coumaroyl-shikimate</data>
      <data key="edge_doi">10.7717/peerj.10741</data>
      <data key="edge_evidence">PtHCT1 and PtHCT6 have been associated with lignin biosynthesis because of their xylem-specific expression profile</data>
    </edge>
    <edge id="e4" source="C3H1" target="Caffeoyl_Shikimate">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">C3'H (CYP98A) hydroxylates p-coumaroyl-shikimate at the 3'-position</data>
      <data key="edge_doi">10.1073/pnas.0706537105</data>
      <data key="edge_evidence">C3'H is a cytochrome P450-dependent monooxygenase that catalyzes the 3'-hydroxylation of p-coumaroyl shikimate and p-coumaroyl quinate</data>
    </edge>
    <edge id="e5" source="CSE1" target="Caffeic_Acid">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">CSE hydrolyses caffeoyl-shikimate into caffeic acid and shikimate</data>
      <data key="edge_doi">10.1104/pp.17.00920</data>
      <data key="edge_evidence">CSE is able to catalyze the conversion of caffeoyl shikimate into caffeate in Arabidopsis</data>
    </edge>
    <edge id="e6" source="CCOAOMT1" target="Feruloyl_CoA">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">CCoAOMT methylates caffeoyl-CoA to feruloyl-CoA, the shared precursor of G and S branches</data>
      <data key="edge_doi">10.1104/pp.124.2.563</data>
      <data key="edge_evidence">reduction in CCoAOMT could effectively affect the availability of the substrate feruloyl CoA</data>
    </edge>
    <edge id="e7" source="CCR2" target="Coniferaldehyde">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">CCR reduces feruloyl-CoA to coniferaldehyde, the central G/S branch-point aldehyde</data>
      <data key="edge_doi">10.1105/tpc.107.054148</data>
      <data key="edge_evidence">CCR catalyzes the conversion of feruloyl-CoA to coniferaldehyde in monolignol biosynthesis</data>
    </edge>
    <edge id="e8" source="F5H1" target="Hydroxyconiferaldehyde">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">F5H1/CAld5H hydroxylates coniferaldehyde at the 5-position, committing flux to the S-branch</data>
      <data key="edge_doi">10.1073/pnas.96.16.8955</data>
      <data key="edge_evidence">CAld5H catalyzes 5-hydroxylation of coniferyl aldehyde into 5-hydroxyconiferyl aldehyde</data>
    </edge>
    <edge id="e9" source="COMT1" target="Sinapaldehyde">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">COMT methylates the 5-OH of 5-hydroxyconiferaldehyde to produce sinapaldehyde</data>
      <data key="edge_doi">10.1073/pnas.96.16.8955</data>
      <data key="edge_evidence">5-hydroxyconiferyl aldehyde was converted exclusively into sinapyl aldehyde when incubated with LsCOMT</data>
    </edge>
    <edge id="e10" source="CAD1" target="Coniferyl_Alcohol">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">CAD1 reduces coniferaldehyde to coniferyl alcohol, the G monolignol</data>
      <data key="edge_doi">10.1104/pp.112.4.1479</data>
      <data key="edge_evidence">CAD catalyzes the last step in the biosynthesis of the lignin precursors, the monolignols</data>
    </edge>
    <edge id="e11" source="CAD1" target="Sinapyl_Alcohol">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">CAD1 reduces sinapaldehyde to sinapyl alcohol, the S monolignol</data>
      <data key="edge_doi">10.1104/pp.112.4.1479</data>
      <data key="edge_evidence">CAD reduces both coniferaldehyde and sinapaldehyde to the respective alcohols</data>
    </edge>
    <edge id="e12" source="Cinnamate" target="P_Coumarate">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Substrate flux via C4H: depletion of cinnamate (e.g., PAL1 KO) propagates to reduce p-coumarate pool</data>
      <data key="edge_doi">10.3389/fpls.2020.00652</data>
      <data key="edge_evidence">C4H hydroxylates cinnamate to p-coumarate</data>
    </edge>
    <edge id="e13" source="P_Coumarate" target="P_Coumaroyl_CoA">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">p-Coumarate is the 4CL substrate; depletion upstream reduces the CoA-thioester pool</data>
      <data key="edge_doi">10.1104/pp.110.159269</data>
      <data key="edge_evidence">4CL catalyses the activation of 4-coumarate to 4-coumaroyl-CoA</data>
    </edge>
    <edge id="e14" source="P_Coumaroyl_CoA" target="P_Coumaroyl_Shikimate">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">p-Coumaroyl-CoA substrate flux via HCT</data>
      <data key="edge_doi">10.7717/peerj.10741</data>
      <data key="edge_evidence">PtoHCT1 from Populus tomentosa was characterised in vitro, generating caffeoyl shikimate (from p-coumaroyl shikimate intermediate)</data>
    </edge>
    <edge id="e15" source="P_Coumaroyl_Shikimate" target="Caffeoyl_Shikimate">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Substrate flux via C3'H</data>
      <data key="edge_doi">10.1073/pnas.0706537105</data>
      <data key="edge_evidence">C3'H catalyses 3'-hydroxylation of p-coumaroyl shikimate</data>
    </edge>
    <edge id="e16" source="Caffeoyl_Shikimate" target="Caffeic_Acid">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">CSE-mediated substrate flux; caffeoyl-shikimate is hydrolysed to caffeic acid</data>
      <data key="edge_doi">10.1104/pp.17.00920</data>
      <data key="edge_evidence">CSE is able to catalyze the conversion of caffeoyl shikimate into caffeate</data>
    </edge>
    <edge id="e17" source="Caffeic_Acid" target="Caffeoyl_CoA">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">4CL5 compensatory activation produces caffeoyl-CoA</data>
      <data key="edge_doi">10.1104/pp.19.01550</data>
      <data key="edge_evidence">Combined activity of CSE with that of 4CL, producing caffeoyl-CoA</data>
    </edge>
    <edge id="e18" source="Caffeoyl_CoA" target="Feruloyl_CoA">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">CCoAOMT substrate flux</data>
      <data key="edge_doi">10.1104/pp.124.2.563</data>
      <data key="edge_evidence">CCoAOMT methylates caffeoyl-CoA to feruloyl-CoA</data>
    </edge>
    <edge id="e19" source="Feruloyl_CoA" target="Coniferaldehyde">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">CCR substrate flux</data>
      <data key="edge_doi">10.1105/tpc.107.054148</data>
      <data key="edge_evidence">CCR converts feruloyl-CoA to coniferaldehyde</data>
    </edge>
    <edge id="e20" source="Coniferaldehyde" target="Hydroxyconiferaldehyde">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">F5H1 substrate flux into the S-branch</data>
      <data key="edge_doi">10.1073/pnas.96.16.8955</data>
      <data key="edge_evidence">coniferyl aldehyde is the preferred substrate for CAld5H</data>
    </edge>
    <edge id="e21" source="Coniferaldehyde" target="Coniferyl_Alcohol">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">CAD substrate flux for G-branch</data>
      <data key="edge_doi">10.1104/pp.112.4.1479</data>
      <data key="edge_evidence">CAD reduces coniferaldehyde to coniferyl alcohol</data>
    </edge>
    <edge id="e22" source="Hydroxyconiferaldehyde" target="Sinapaldehyde">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">COMT substrate flux</data>
      <data key="edge_doi">10.1073/pnas.96.16.8955</data>
      <data key="edge_evidence">5-hydroxyconiferyl aldehyde was converted exclusively into sinapyl aldehyde when incubated with LsCOMT</data>
    </edge>
    <edge id="e23" source="Sinapaldehyde" target="Sinapyl_Alcohol">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">CAD substrate flux for S-branch</data>
      <data key="edge_doi">10.1104/pp.112.4.1479</data>
      <data key="edge_evidence">CAD reduces cinnamaldehydes to corresponding alcohols</data>
    </edge>
    <edge id="e24" source="F5H1" target="Lignin_SG_Ratio">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">F5H1 is the rate-limiting S-branch enzyme; its activity level is the dominant determinant of poplar S/G</data>
      <data key="edge_doi">10.1104/pp.109.137059</data>
      <data key="edge_evidence">C4H::F5H transgenic lignin was comprised of as much as 97.5% syringyl units; the syringyl level in the wild-type control was 68%</data>
    </edge>
    <edge id="e25" source="Sinapyl_Alcohol" target="Lignin_SG_Ratio">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Sinapyl alcohol is the S monolignol feeding the S numerator of the S/G ratio</data>
      <data key="edge_doi">10.1104/pp.109.137059</data>
      <data key="edge_evidence">F5H affects the partitioning between the two major traditional monolignols, coniferyl and sinapyl alcohols</data>
    </edge>
    <edge id="e26" source="MYB152" target="Lignin_SG_Ratio">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">PtrMYB152 OE in Arabidopsis raised S/G monomer ratio from 0.31 (WT) to 0.37-0.42</data>
      <data key="edge_doi">10.1038/srep05054</data>
      <data key="edge_evidence">S/G monomer ratio was higher in the transgenic plants than wild-type (0.37-0.42 vs 0.31)</data>
    </edge>
    <edge id="e27" source="Tension_Wood" target="Lignin_SG_Ratio">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Tension wood fibres in WT poplar deposit a higher proportion of syringyl units than normal or opposite wood</data>
      <data key="edge_doi">10.1093/treephys/tpt013</data>
      <data key="edge_evidence">In the wild-type poplar, the lignin in tension wood contained a significantly higher percentage of syringyl than normal wood or opposite wood</data>
    </edge>
    <edge id="e28" source="Coniferyl_Alcohol" target="Lignin_SG_Ratio">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">Coniferyl alcohol is the G monolignol feeding the G denominator of the S/G ratio; excess G lowers the ratio</data>
      <data key="edge_doi">10.1104/pp.109.137059</data>
      <data key="edge_evidence">only coupling of a monolignol with a G unit can result in beta-5-coupled products; G-unit surplus lowers S/G</data>
    </edge>
    <edge id="e29" source="C3H1" target="Lignin_SG_Ratio">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">In poplar, C3H downregulation preferentially reduces G units at the expense of H accumulation, raising S/G ratio from ~1.7 to ~3.6 â€” encoded as C3H net-negative on S/G</data>
      <data key="edge_doi">10.1007/s12155-012-9218-y</data>
      <data key="edge_evidence">C3H downregulation reduced lignin levels by half and markedly increased the proportion of H units; G/S went from 0.59 WT to 0.28 C3H (so S/G roughly doubled)</data>
    </edge>
