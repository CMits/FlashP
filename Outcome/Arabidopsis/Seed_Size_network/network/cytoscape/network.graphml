    <edge id="e0" source="Integument_Growth" target="Seed_Size">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">integument cell number + elongation sets final seed coat volume</data>
      <data key="edge_doi">10.1105/tpc.113.115063</data>
      <data key="edge_evidence">maternal integument or seed coat sets upper limit to final seed size</data>
    </edge>
    <edge id="e1" source="Endosperm_Proliferation" target="Seed_Size">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">endosperm cavity volume determines final seed size</data>
      <data key="edge_doi">10.3390/ijms241310666</data>
      <data key="edge_evidence">major endosperm/seed growth phase is driven by expansion of coenocytic endosperm; conditions final size of embryo</data>
    </edge>
    <edge id="e2" source="Ovule_size" target="Seed_Size">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">larger ovules Ã¢â€ â€™ larger fertilized seeds</data>
      <data key="edge_doi">10.1242/dev.201853</data>
      <data key="edge_evidence">Increase in cell number in ovule integuments leads to increase in ovule size and seed size</data>
    </edge>
    <edge id="e3" source="ABA" target="Seed_Size">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">maternal ABA restricts endosperm proliferation</data>
      <data key="edge_doi">10.1105/tpc.113.121566</data>
      <data key="edge_evidence">ABA-deficient mutants produced seeds with increased size; abi5 mutant larger seeds</data>
    </edge>
    <edge id="e4" source="UBP15" target="Integument_Growth">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">UBP15 deubiquitinates growth-promoting substrates; promotes cell proliferation</data>
      <data key="edge_doi">10.1105/tpc.114.122663</data>
      <data key="edge_evidence">UBP15 influences seed size by promoting cell proliferation in the maternal integuments</data>
    </edge>
    <edge id="e5" source="KLUH" target="Integument_Growth">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">CYP78A5 generates mobile growth signal from inner integument that stimulates cell proliferation</data>
      <data key="edge_doi">10.1073/pnas.0907024106</data>
      <data key="edge_evidence">outer integuments were longer and consisted of more cells in pINO::KLU-expressing plants; klu-2 mutant ovules had shorter integuments with fewer cells</data>
    </edge>
    <edge id="e6" source="TTG2" target="Integument_Growth">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">WRKY TF promotes integument cell elongation and tannin synthesis</data>
      <data key="edge_doi">10.1073/pnas.0907024106</data>
      <data key="edge_evidence">TTG2 gene acts maternally to promote cell expansion in integuments</data>
    </edge>
    <edge id="e7" source="GIF1" target="Integument_Growth">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">GIF1 acts as transcriptional co-activator with GRFs</data>
      <data key="edge_doi">10.1038/s41467-020-15603-3</data>
      <data key="edge_evidence">gif1 mutants reduced cell number in outer integuments; 35S:GIF1 produces larger seeds</data>
    </edge>
    <edge id="e8" source="Auxin" target="Integument_Growth">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">auxin drives seed coat cell elongation and differentiation</data>
      <data key="edge_doi">10.7554/eLife.20542</data>
      <data key="edge_evidence">2,4-D treated ovules larger; 30-40% show seed coat development without fertilization</data>
    </edge>
    <edge id="e9" source="Cell_Proliferation_Duration" target="Integument_Growth">
      <data key="edge_sign">positive</data>
      <data key="edge_color">#228B22</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">longer proliferation period Ã¢â€ â€™ more integument cells</data>
      <data key="edge_doi">10.4161/psb.21620</data>
      <data key="edge_evidence">AGG3 extends proliferation period yielding larger organs</data>
    </edge>
    <edge id="e10" source="DA1" target="Integument_Growth">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">DA1 restricts cell proliferation in maternal integuments</data>
      <data key="edge_doi">10.1105/tpc.114.122663</data>
      <data key="edge_evidence">DA1 acts maternally to affect seed growth by restricting cell proliferation in the integuments</data>
    </edge>
    <edge id="e11" source="DA2" target="Integument_Growth">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">DA2 RING E3 ligase restricts integument cell proliferation</data>
      <data key="edge_doi">10.1105/tpc.113.115063</data>
      <data key="edge_evidence">DA2 acts synergistically with DA1 to restrict cell proliferation in maternal integuments</data>
    </edge>
    <edge id="e12" source="EOD1" target="Integument_Growth">
      <data key="edge_sign">negative</data>
      <data key="edge_color">#DC143C</data>
      <data key="edge_confidence">MEDIUM</data>
      <data key="edge_mechanism">EOD1/BB RING E3 ligase restricts cell proliferation</data>
      <data key="edge_doi">10.1105/tpc.114.122663</data>
      <data key="edge_evidence">EOD1/BB and DA1 act synergistically to restrict cell proliferation</data>
    </edge>
    <edge id="e13" source="SOD7" target="Integument_Growth">
      <data key="edge_sign">negative</data>
