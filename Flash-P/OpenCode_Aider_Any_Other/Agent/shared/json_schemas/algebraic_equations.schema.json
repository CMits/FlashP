{
  "$defs": {
    "AlgebraicEquation": {
      "properties": {
        "node": {
          "title": "Node",
          "type": "string"
        },
        "type": {
          "$ref": "#/$defs/NodeType"
        },
        "is_source": {
          "default": false,
          "title": "Is Source",
          "type": "boolean"
        },
        "activators": {
          "items": {
            "type": "string"
          },
          "title": "Activators",
          "type": "array"
        },
        "inhibitors": {
          "items": {
            "type": "string"
          },
          "title": "Inhibitors",
          "type": "array"
        },
        "formula": {
          "description": "The algebraic equation formula string",
          "title": "Formula",
          "type": "string"
        }
      },
      "required": [
        "node",
        "type",
        "formula"
      ],
      "title": "AlgebraicEquation",
      "type": "object"
    },
    "AlgebraicEquationsMetadata": {
      "properties": {
        "flash_p_version": {
          "description": "Pipeline version, e.g. '1.0'",
          "title": "Flash P Version",
          "type": "string"
        },
        "phenotype": {
          "description": "Target phenotype, e.g. 'flowering_time'",
          "title": "Phenotype",
          "type": "string"
        },
        "species": {
          "description": "Species name, e.g. 'Arabidopsis thaliana'",
          "title": "Species",
          "type": "string"
        },
        "created": {
          "description": "Creation date YYYY-MM-DD",
          "title": "Created",
          "type": "string"
        },
        "total_equations": {
          "title": "Total Equations",
          "type": "integer"
        }
      },
      "required": [
        "flash_p_version",
        "phenotype",
        "species",
        "created",
        "total_equations"
      ],
      "title": "AlgebraicEquationsMetadata",
      "type": "object"
    },
    "AlgebraicParameters": {
      "properties": {
        "epsilon": {
          "default": 0.1,
          "title": "Epsilon",
          "type": "number"
        },
        "K": {
          "default": 10.0,
          "title": "K",
          "type": "number"
        },
        "activator_floor": {
          "default": 0.01,
          "title": "Activator Floor",
          "type": "number"
        },
        "damping": {
          "default": 0.7,
          "title": "Damping",
          "type": "number"
        },
        "direction_threshold": {
          "default": 0.05,
          "title": "Direction Threshold",
          "type": "number"
        },
        "max_iterations": {
          "default": 100,
          "title": "Max Iterations",
          "type": "integer"
        },
        "convergence_tolerance": {
          "default": 0.0001,
          "title": "Convergence Tolerance",
          "type": "number"
        }
      },
      "title": "AlgebraicParameters",
      "type": "object"
    },
    "NodeType": {
      "enum": [
        "GENE",
        "HORMONE",
        "METABOLITE",
        "ENVIRONMENT",
        "PROTEIN_COMPLEX",
        "REGULATORY_RNA",
        "PHENOTYPE",
        "PROCESS"
      ],
      "title": "NodeType",
      "type": "string"
    }
  },
  "properties": {
    "metadata": {
      "$ref": "#/$defs/AlgebraicEquationsMetadata"
    },
    "parameters": {
      "$ref": "#/$defs/AlgebraicParameters"
    },
    "equations": {
      "items": {
        "$ref": "#/$defs/AlgebraicEquation"
      },
      "title": "Equations",
      "type": "array"
    }
  },
  "required": [
    "metadata",
    "parameters",
    "equations"
  ],
  "title": "AlgebraicEquationsFile",
  "type": "object"
}