{
  "$defs": {
    "CandidatePaper": {
      "properties": {
        "doi": {
          "title": "Doi",
          "type": "string"
        },
        "title": {
          "title": "Title",
          "type": "string"
        },
        "authors": {
          "default": "",
          "title": "Authors",
          "type": "string"
        },
        "year": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Year"
        },
        "journal": {
          "default": "",
          "title": "Journal",
          "type": "string"
        },
        "status": {
          "default": "read",
          "description": "read | skipped | paywalled",
          "title": "Status",
          "type": "string"
        },
        "pmc_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Pmc Id"
        }
      },
      "required": [
        "doi",
        "title"
      ],
      "title": "CandidatePaper",
      "type": "object"
    },
    "CandidatePapersMetadata": {
      "properties": {
        "flash_p_version": {
          "description": "Pipeline version, e.g. '2.0'",
          "title": "Flash P Version",
          "type": "string"
        },
        "phenotype": {
          "description": "Target phenotype, e.g. 'flowering_time'",
          "title": "Phenotype",
          "type": "string"
        },
        "species": {
          "description": "Species name, e.g. 'Arabidopsis thaliana'",
          "title": "Species",
          "type": "string"
        },
        "created": {
          "description": "Creation date YYYY-MM-DD",
          "title": "Created",
          "type": "string"
        },
        "total_papers": {
          "title": "Total Papers",
          "type": "integer"
        }
      },
      "required": [
        "flash_p_version",
        "phenotype",
        "species",
        "created",
        "total_papers"
      ],
      "title": "CandidatePapersMetadata",
      "type": "object"
    }
  },
  "properties": {
    "metadata": {
      "$ref": "#/$defs/CandidatePapersMetadata"
    },
    "papers": {
      "items": {
        "$ref": "#/$defs/CandidatePaper"
      },
      "title": "Papers",
      "type": "array"
    }
  },
  "required": [
    "metadata",
    "papers"
  ],
  "title": "CandidatePapersFile",
  "type": "object"
}