{
  "$defs": {
    "EvidenceEntry": {
      "description": "Flat evidence structure — used everywhere.\nNEVER nested (no 'source' sub-object).",
      "properties": {
        "doi": {
          "description": "DOI of the source paper",
          "title": "Doi",
          "type": "string"
        },
        "title": {
          "default": "",
          "description": "Paper title",
          "title": "Title",
          "type": "string"
        },
        "authors": {
          "default": "",
          "description": "Author list",
          "title": "Authors",
          "type": "string"
        },
        "year": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Publication year",
          "title": "Year"
        },
        "journal": {
          "default": "",
          "description": "Journal name",
          "title": "Journal",
          "type": "string"
        },
        "evidence_sentence": {
          "default": "",
          "description": "Exact quote from paper supporting this claim",
          "title": "Evidence Sentence",
          "type": "string"
        },
        "claim": {
          "default": "",
          "description": "What this evidence supports",
          "title": "Claim",
          "type": "string"
        },
        "verification": {
          "anyOf": [
            {
              "$ref": "#/$defs/Verification"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "How the paper was read"
        },
        "full_text_read": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Whether full text was read",
          "title": "Full Text Read"
        }
      },
      "required": [
        "doi"
      ],
      "title": "EvidenceEntry",
      "type": "object"
    },
    "NetworkEdge": {
      "properties": {
        "source": {
          "title": "Source",
          "type": "string"
        },
        "target": {
          "title": "Target",
          "type": "string"
        },
        "sign": {
          "description": "1 = activation, -1 = inhibition",
          "title": "Sign",
          "type": "integer"
        },
        "edge_id": {
          "default": "",
          "description": "Edge identifier, e.g. N001",
          "title": "Edge Id",
          "type": "string"
        },
        "effect": {
          "default": "",
          "description": "activation, repression, inhibition",
          "title": "Effect",
          "type": "string"
        },
        "mechanism": {
          "default": "",
          "description": "Biological mechanism",
          "title": "Mechanism",
          "type": "string"
        },
        "evidence": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/EvidenceEntry"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Evidence"
        }
      },
      "required": [
        "source",
        "target",
        "sign"
      ],
      "title": "NetworkEdge",
      "type": "object"
    },
    "NetworkMetadata": {
      "properties": {
        "flash_p_version": {
          "description": "Pipeline version, e.g. '2.0'",
          "title": "Flash P Version",
          "type": "string"
        },
        "phenotype": {
          "description": "Target phenotype, e.g. 'flowering_time'",
          "title": "Phenotype",
          "type": "string"
        },
        "species": {
          "description": "Species name, e.g. 'Arabidopsis thaliana'",
          "title": "Species",
          "type": "string"
        },
        "created": {
          "description": "Creation date YYYY-MM-DD",
          "title": "Created",
          "type": "string"
        },
        "total_nodes": {
          "title": "Total Nodes",
          "type": "integer"
        },
        "total_edges": {
          "title": "Total Edges",
          "type": "integer"
        },
        "source_nodes": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Nodes"
        },
        "source_percentage": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Percentage"
        }
      },
      "required": [
        "flash_p_version",
        "phenotype",
        "species",
        "created",
        "total_nodes",
        "total_edges"
      ],
      "title": "NetworkMetadata",
      "type": "object"
    },
    "NetworkNode": {
      "properties": {
        "id": {
          "description": "Node identifier, e.g. FLC, Auxin, Flowering_Time",
          "title": "Id",
          "type": "string"
        },
        "type": {
          "$ref": "#/$defs/NodeType"
        },
        "full_name": {
          "default": "",
          "description": "Full descriptive name",
          "title": "Full Name",
          "type": "string"
        },
        "description": {
          "default": "",
          "description": "Biological description",
          "title": "Description",
          "type": "string"
        },
        "is_source": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "True for nodes with no regulators (environment, constitutive)",
          "title": "Is Source"
        }
      },
      "required": [
        "id",
        "type"
      ],
      "title": "NetworkNode",
      "type": "object"
    },
    "NodeType": {
      "enum": [
        "GENE",
        "HORMONE",
        "METABOLITE",
        "ENVIRONMENT",
        "PROTEIN_COMPLEX",
        "REGULATORY_RNA",
        "PHENOTYPE",
        "PROCESS"
      ],
      "title": "NodeType",
      "type": "string"
    },
    "Verification": {
      "enum": [
        "full_text_read",
        "abstract_read",
        "pubmed_crosschecked"
      ],
      "title": "Verification",
      "type": "string"
    }
  },
  "properties": {
    "metadata": {
      "$ref": "#/$defs/NetworkMetadata"
    },
    "nodes": {
      "items": {
        "$ref": "#/$defs/NetworkNode"
      },
      "title": "Nodes",
      "type": "array"
    },
    "edges": {
      "items": {
        "$ref": "#/$defs/NetworkEdge"
      },
      "title": "Edges",
      "type": "array"
    }
  },
  "required": [
    "metadata",
    "nodes",
    "edges"
  ],
  "title": "NetworkFile",
  "type": "object"
}